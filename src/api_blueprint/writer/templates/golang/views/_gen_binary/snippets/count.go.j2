{% if field.count_is_literal %}
count := uint64({{ field.count }})
{% else %}
count, err := evalBinaryExpr(vars, {{ field.count | code_literal }})
if err != nil {
	return fmt.Errorf("%s: invalid count {{ field.count }}: %w", {{ path_expr | safe }}, err)
}
{% endif %}
{% if field.max_value %}
maxCount, err := evalBinaryExpr(vars, {{ field.max_value | code_literal }})
if err != nil {
	return fmt.Errorf("%s: invalid max {{ field.max_value }}: %w", {{ path_expr | safe }}, err)
}
if count > maxCount {
	return fmt.Errorf("%s: count %d exceeds max %d", {{ path_expr | safe }}, count, maxCount)
}
{% endif %}
if count > uint64(int(^uint(0)>>1)) {
	return fmt.Errorf("%s: count %d exceeds platform int max", {{ path_expr | safe }}, count)
}
