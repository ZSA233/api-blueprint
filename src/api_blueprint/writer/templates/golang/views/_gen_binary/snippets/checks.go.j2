{% if field.const_value %}
{% if field.is_bytes %}
if string(out.{{ field.go_name }}[:]) != {{ field.const_value | code_literal }} {
	return fmt.Errorf("%s: const mismatch", {{ path_expr | safe }})
}
{% elif field.is_string %}
if out.{{ field.go_name }} != {{ field.const_value | code_literal }} {
	return fmt.Errorf("%s: const mismatch", {{ path_expr | safe }})
}
{% else %}
if fmt.Sprint(out.{{ field.go_name }}) != {{ field.const_value | code_literal }} {
	return fmt.Errorf("%s: const mismatch", {{ path_expr | safe }})
}
{% endif %}
{% endif %}
{% if field.min_value and field.supports_numeric_rules %}
minLimit, err := evalBinaryExpr(vars, {{ field.min_value | code_literal }})
if err != nil {
	return fmt.Errorf("%s: invalid min {{ field.min_value }}: %w", {{ path_expr | safe }}, err)
}
if uint64(out.{{ field.go_name }}) < minLimit {
	return fmt.Errorf("%s: below min", {{ path_expr | safe }})
}
{% endif %}
{% if field.max_value and field.supports_numeric_rules %}
maxLimit, err := evalBinaryExpr(vars, {{ field.max_value | code_literal }})
if err != nil {
	return fmt.Errorf("%s: invalid max {{ field.max_value }}: %w", {{ path_expr | safe }}, err)
}
if uint64(out.{{ field.go_name }}) > maxLimit {
	return fmt.Errorf("%s: exceeds max", {{ path_expr | safe }})
}
{% endif %}
{% if field.assert_value and field.supports_numeric_rules %}
expected, err := evalBinaryExpr(vars, {{ field.assert_value | code_literal }})
if err != nil {
	return fmt.Errorf("%s: invalid assert {{ field.assert_value }}: %w", {{ path_expr | safe }}, err)
}
if uint64(out.{{ field.go_name }}) != expected {
	return fmt.Errorf("%s: assert mismatch", {{ path_expr | safe }})
}
{% endif %}
