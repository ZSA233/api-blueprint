{% autoescape false %}import 'dart:async';
import 'dart:convert';
import 'dart:typed_data';

import 'package:http/http.dart' as http;
import 'package:web_socket_channel/web_socket_channel.dart';

import '../../runtime/gen_api_errors.dart';
import '../../runtime/gen_api_transport.dart';
import 'gen_http_api_config.dart';
import 'gen_http_connection.dart';

class HttpApiTransport implements ApiTransport {
  final HttpApiConfig config;
  final http.Client _client;

  HttpApiTransport({this.config = const HttpApiConfig(), http.Client? client})
      : _client = client ?? config.client ?? http.Client();

  @override
  Future<T> request<T>(ApiRequest<T> request) async {
    final url = _buildUrl(request.path, request.query);
    final headers = {
      ...config.defaultHeaders,
      ...request.options.headers,
    };
    Object? body;
    if (request.json != null) {
      headers.putIfAbsent('Content-Type', () => 'application/json');
      body = jsonEncode(apiBlueprintToJson(request.json));
    } else if (request.form != null) {
      headers.putIfAbsent('Content-Type', () => 'application/x-www-form-urlencoded');
      body = _encodeFormBody(request.form);
    } else if (request.binary != null) {
      headers.putIfAbsent('Content-Type', () => request.binaryContentType ?? 'application/octet-stream');
      body = request.binary;
    }

    Future<http.StreamedResponse> send() {
      if (request.multipart != null) {
        final multipartRequest = http.MultipartRequest(request.method, url)..headers.addAll(headers);
        _appendMultipart(multipartRequest, request.multipart);
        return _client.send(multipartRequest);
      }
      return _client.send(http.Request(request.method, url)
        ..headers.addAll(headers)
        ..bodyBytes = body is List<int> ? body : utf8.encode(body?.toString() ?? ''));
    }

    final timeout = request.options.timeout ?? config.timeout;
    if (request.responseKind == 'byte_stream') {
      final response = timeout == null ? await send() : await send().timeout(timeout);
      if (response.statusCode < 200 || response.statusCode >= 300) {
        final errorBody = response.stream.transform(utf8.decoder).join();
        final body = timeout == null ? await errorBody : await errorBody.timeout(timeout);
        final payload = _decodeBody(body);
        throw ApiError(
          extractApiErrorPayload(payload, request.routeId, request.responseEnvelope),
          routeId: request.routeId,
          raw: payload,
        );
      }
      if (_isJsonContent(response.headers)) {
        final errorBody = response.stream.transform(utf8.decoder).join();
        final body = timeout == null ? await errorBody : await errorBody.timeout(timeout);
        final payload = _decodeBody(body);
        _throwRawApiErrorIfPresent(payload, request);
        return decodeApiResponse(
          ApiStreamResponse(
            body: Stream<List<int>>.value(utf8.encode(body)),
            contentType: _contentType(response.headers, request.responseMediaType),
            headers: response.headers,
          ),
          request,
        );
      }
      return decodeApiResponse(
        ApiStreamResponse(
          body: response.stream,
          contentType: _contentType(response.headers, request.responseMediaType),
          headers: response.headers,
        ),
        request,
      );
    }

    final buffered = send().then(http.Response.fromStream);
    final response = timeout == null ? await buffered : await buffered.timeout(timeout);
    if (response.statusCode < 200 || response.statusCode >= 300) {
      final payload = _decodeBody(response.body);
      throw ApiError(
        extractApiErrorPayload(payload, request.routeId, request.responseEnvelope),
        routeId: request.routeId,
        raw: payload,
      );
    }
    final binaryPayload =
        request.responseKind == 'bytes' || request.responseKind == 'file' || request.responseKind == 'binary_schema';
    if ((request.responseKind == 'bytes' || request.responseKind == 'file') && _isJsonContent(response.headers)) {
      _throwRawApiErrorIfPresent(_decodeBody(response.body), request);
    }
    final payload = binaryPayload
        ? ApiBinaryPayload(Uint8List.fromList(response.bodyBytes), response.headers)
        : _decodeBody(response.body);
    return decodeApiResponse(payload, request);
  }

  @override
  ApiStreamBridge<Recv, Close> openStream<Recv, Close>(StreamConnectOptions<Recv, Close> options) {
    return HttpEventStreamBridge(
      routeId: options.routeId,
      start: () => _client.send(http.Request('GET', _buildUrl(options.path, options.query))
        ..headers.addAll({
          ...config.defaultHeaders,
          ...options.headers,
          'Accept': 'text/event-stream',
        })),
      decodeMessage: options.decodeMessage,
      decodeClose: options.decodeClose,
    );
  }

  @override
  ApiChannelBridge<Recv, Send, Close> openChannel<Recv, Send, Close>(
    ChannelConnectOptions<Recv, Send, Close> options,
  ) {
    final socket = WebSocketChannel.connect(_buildWsUrl(options.path, options.query), protocols: options.protocols);
    return HttpSocketBridge(
      routeId: options.routeId,
      socket: socket,
      decodeMessage: options.decodeMessage,
      encodeMessage: options.encodeMessage,
      decodeClose: options.decodeClose,
    );
  }

  Uri _buildUrl(String path, Map<String, String?> query) {
    final normalizedBase = config.baseUrl.replaceFirst(RegExp(r'/$'), '');
    final normalizedPath = path.startsWith('/') ? path : '/$path';
    final raw = normalizedBase.isEmpty ? normalizedPath : '$normalizedBase$normalizedPath';
    final url = Uri.parse(raw);
    final queryParams = {
      ...url.queryParameters,
      for (final entry in query.entries)
        if (entry.value != null) entry.key: entry.value!,
    };
    return url.replace(queryParameters: queryParams.isEmpty ? null : queryParams);
  }

  Uri _buildWsUrl(String path, Map<String, String?> query) {
    final url = _buildUrl(path, query);
    if (url.scheme == 'http') {
      return url.replace(scheme: 'ws');
    }
    if (url.scheme == 'https') {
      return url.replace(scheme: 'wss');
    }
    return url;
  }
}

String _contentType(Map<String, String> headers, String defaultValue) {
  for (final entry in headers.entries) {
    if (entry.key.toLowerCase() == 'content-type') {
      return entry.value;
    }
  }
  return defaultValue;
}

bool _isJsonContent(Map<String, String> headers) {
  final contentType = _contentType(headers, '').split(';').first.trim().toLowerCase();
  return contentType == 'application/json' || contentType.endsWith('+json');
}

void _throwRawApiErrorIfPresent<T>(Object? payload, ApiRequest<T> request) {
  final envelope = request.responseEnvelope;
  if (envelope.kind == 'none') {
    return;
  }
  final root = apiBlueprintReadObject(payload);
  if (root.isEmpty) {
    return;
  }
  if (envelope.kind == 'code_message_data') {
    final code = apiBlueprintReadInt(root[envelope.fields.code]);
    if (code == null || code == envelope.successCode) {
      return;
    }
    throw ApiError(
      extractApiErrorPayload(payload, request.routeId, envelope),
      routeId: request.routeId,
      raw: payload,
    );
  }
  if (envelope.kind == 'ok_data_error') {
    final ok = apiBlueprintReadBool(root[envelope.fields.ok]);
    if (ok != false) {
      return;
    }
    throw ApiError(
      extractApiErrorPayload(payload, request.routeId, envelope),
      routeId: request.routeId,
      raw: payload,
    );
  }
}

Object? _decodeBody(String body) {
  if (body.isEmpty) {
    return null;
  }
  try {
    return jsonDecode(body);
  } catch (_) {
    return body;
  }
}

String _encodeFormBody(Object? form) {
  final object = apiBlueprintReadObject(apiBlueprintToJson(form));
  final values = <String, String>{};
  for (final entry in object.entries) {
    final value = apiBlueprintToQueryValue(entry.value);
    if (value != null) {
      values[entry.key] = value;
    }
  }
  return Uri(queryParameters: values).query;
}

void _appendMultipart(http.MultipartRequest request, Object? multipart) {
  final object = apiBlueprintReadObject(apiBlueprintToJson(multipart));
  for (final entry in object.entries) {
    final file = _filePart(entry.value);
    if (file != null) {
      request.files.add(http.MultipartFile(
        entry.key,
        file.openStream(),
        file.length ?? file.bytes.length,
        filename: file.filename.isEmpty ? entry.key : file.filename,
      ));
      continue;
    }
    final value = apiBlueprintToQueryValue(entry.value);
    if (value != null) {
      request.fields[entry.key] = value;
    }
  }
}

ApiFilePart? _filePart(Object? value) {
  if (value is ApiFilePart) {
    return value;
  }
  final object = apiBlueprintReadObject(value);
  final stream = object['stream'];
  final length = apiBlueprintReadInt(object['length']);
  if (stream is Stream<List<int>> && length != null) {
    return ApiFilePart.fromStream(
      filename: apiBlueprintReadString(object['filename']) ?? '',
      contentType: apiBlueprintReadString(object['contentType']) ?? 'application/octet-stream',
      body: stream,
      length: length,
    );
  }
  if (!object.containsKey('bytes')) {
    return null;
  }
  return ApiFilePart.fromJson(object);
}
