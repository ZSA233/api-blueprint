{% autoescape false %}class ApiError implements Exception {
  final ApiErrorPayload payload;
  final String routeId;
  final Object? raw;

  const ApiError(this.payload, {this.routeId = '', this.raw});

  @override
  String toString() => 'ApiError(${payload.code}, ${payload.message})';
}

class ApiException implements Exception {
  final int statusCode;
  final Object? body;

  const ApiException(this.statusCode, this.body);

  @override
  String toString() => 'ApiException($statusCode)';
}

class ApiErrorPayload {
  final String id;
  final String group;
  final String key;
  final int code;
  final String message;
  final ApiToastPayload toast;
  final String routeId;

  const ApiErrorPayload({
    this.id = '',
    this.group = '',
    this.key = '',
    this.code = 0,
    this.message = '',
    this.toast = const ApiToastPayload(),
    this.routeId = '',
  });

  factory ApiErrorPayload.fromJson(Object? value, {String routeId = ''}) {
    final json = apiBlueprintReadObject(value);
    return ApiErrorPayload(
      id: apiBlueprintReadString(json['id']) ?? '',
      group: apiBlueprintReadString(json['group']) ?? '',
      key: apiBlueprintReadString(json['key']) ?? '',
      code: apiBlueprintReadInt(json['code']) ?? 0,
      message: apiBlueprintReadString(json['message']) ?? '',
      toast: ApiToastPayload.fromJson(json['toast']),
      routeId: routeId,
    );
  }
}

class ApiToastPayload {
  final String key;
  final String level;
  final String defaultMessage;
  final String text;

  const ApiToastPayload({
    this.key = '',
    this.level = '',
    this.defaultMessage = '',
    this.text = '',
  });

  factory ApiToastPayload.fromJson(Object? value) {
