}

class ApiToastSpec {
  final String key;
  final String level;
  final String defaultMessage;
  final String text;

  const ApiToastSpec({
    this.key = '',
    this.level = 'error',
    this.defaultMessage = '',
    this.text = '',
  });
}

ApiToastSpec resolveApiToast(ApiErrorPayload payload, {String fallbackMessage = ''}) {
  return ApiToastSpec(
    key: payload.toast.key,
    level: payload.toast.level.isEmpty ? 'error' : payload.toast.level,
    defaultMessage: payload.toast.defaultMessage.isEmpty ? payload.message : payload.toast.defaultMessage,
    text: payload.toast.text.isEmpty ? fallbackMessage : payload.toast.text,
  );
}

T apiBlueprintRequire<T>(T? value, String label) {
  if (value == null) {
    throw FormatException('Expected $label');
  }
  return value;
}

Object? apiBlueprintToJson(Object? value) {
  if (value == null || value is num || value is String || value is bool) {
    return value;
  }
  final dynamic dynamicValue = value;
  try {
    return dynamicValue.wireValue;
  } catch (_) {
    // Fall through to structured JSON conversion.
  }
  if (value is List) {
    return value.map(apiBlueprintToJson).toList();
  }
  if (value is Map) {
    return value.map((key, item) => MapEntry(key.toString(), apiBlueprintToJson(item)));
  }
  try {
    return dynamicValue.toJson();
  } catch (_) {
    return value;
  }
}

String? apiBlueprintToQueryValue(Object? value) {
  final json = apiBlueprintToJson(value);
  return json?.toString();
}

Map<String, Object?> apiBlueprintReadObject(Object? value) {
  if (value is Map<String, Object?>) {
    return value;
  }
  if (value is Map) {
    return value.map((key, item) => MapEntry(key.toString(), item));
  }
  return const {};
}

String? apiBlueprintReadString(Object? value) => value?.toString();

int? apiBlueprintReadInt(Object? value) {
  if (value is int) {
    return value;
  }
  if (value is num) {
    return value.toInt();
  }
  return int.tryParse(value?.toString() ?? '');
}

double? apiBlueprintReadDouble(Object? value) {
  if (value is double) {
    return value;
  }
  if (value is num) {
    return value.toDouble();
  }
  return double.tryParse(value?.toString() ?? '');
}

bool? apiBlueprintReadBool(Object? value) {
  if (value is bool) {
    return value;
  }
  if (value is String) {
    return value == 'true' || value == '1';
  }
  return null;
}

Object? apiBlueprintReadAny(Object? value) => value;

List<T>? apiBlueprintReadList<T>(Object? value, T? Function(Object?) itemReader) {
  if (value is! List) {
    return null;
  }
  return value.map((item) => itemReader(item)).whereType<T>().toList();
}

Map<String, T>? apiBlueprintReadStringMap<T>(Object? value, T? Function(Object?) itemReader) {
  if (value is! Map) {
    return null;
  }
  return value.map((key, item) => MapEntry(key.toString(), itemReader(item))).cast<String, T>();
}
