class ApiResponseEnvelope {
  final String name;
  final String kind;
  final String errorIdentity;
  final int successCode;
  final String successMessage;
  final ApiResponseEnvelopeFields fields;

  const ApiResponseEnvelope({
    this.name = 'NoEnvelope',
    this.kind = 'none',
    this.errorIdentity = 'none',
    this.successCode = 0,
    this.successMessage = 'ok',
    this.fields = const ApiResponseEnvelopeFields(),
  });
}

