class ChannelConnectOptions<Recv, Send, Close> extends StreamConnectOptions<Recv, Close> {
  final Object? Function(Send value) encodeMessage;
  final List<String> protocols;
  final String delivery;

  const ChannelConnectOptions({
    required super.routeId,
    required super.connectionKind,
    required super.path,
    required super.decodeMessage,
    required super.decodeClose,
    required this.encodeMessage,
    this.protocols = const [],
    this.delivery = 'ordered',
    super.query = const {},
