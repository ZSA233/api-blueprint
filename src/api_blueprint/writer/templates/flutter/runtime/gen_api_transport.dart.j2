class ApiRequest<T> {
  final String routeId;
  final String method;
  final String path;
  final Map<String, String?> query;
  final Map<String, String> headers;
  final Object? json;
  final Object? form;
  final Object? multipart;
  final List<int>? binary;
  final String? binaryContentType;
  final String responseMediaType;
  final String responseKind;
  final ApiResponseEnvelope responseEnvelope;
  final T Function(Object? value) decode;

  const ApiRequest({
    required this.routeId,
    required this.method,
    required this.path,
    required this.decode,
    this.query = const {},
    this.headers = const {},
    this.json,
    this.form,
    this.multipart,
    this.binary,
    this.binaryContentType,
    this.responseMediaType = 'application/json',
    this.responseKind = 'json',
    this.responseEnvelope = const ApiResponseEnvelope(),
  });
}

class ApiFilePart {
  final String filename;
  final String contentType;
  final Uint8List bytes;

  const ApiFilePart({
    this.filename = '',
    this.contentType = 'application/octet-stream',
    required this.bytes,
  });

  factory ApiFilePart.fromJson(Object? value) {
    final json = apiBlueprintReadObject(value);
    return ApiFilePart(
      filename: apiBlueprintReadString(json['filename']) ?? '',
      contentType: apiBlueprintReadString(json['contentType']) ?? 'application/octet-stream',
      bytes: apiBlueprintReadBytes(json['bytes']),
    );
  }

  Map<String, Object?> toJson() => {
        'filename': filename,
        'contentType': contentType,
        'bytes': bytes.toList(),
      };
}

class ApiBinaryPayload {
  final Uint8List bytes;
  final Map<String, String> headers;

  const ApiBinaryPayload(this.bytes, this.headers);

  String contentType(String defaultValue) {
    for (final entry in headers.entries) {
      if (entry.key.toLowerCase() == 'content-type') {
        return entry.value;
      }
    }
    return defaultValue;
  }

  String filename(String defaultValue) {
    String? disposition;
    for (final entry in headers.entries) {
      if (entry.key.toLowerCase() == 'content-disposition') {
        disposition = entry.value;
        break;
      }
    }
    if (disposition == null) return defaultValue;
    for (final part in disposition.split(';')) {
      final trimmed = part.trim();
      if (trimmed.toLowerCase().startsWith('filename=')) {
        return trimmed.substring('filename='.length).replaceAll('"', '').trim();
      }
    }
    return defaultValue;
  }
}

