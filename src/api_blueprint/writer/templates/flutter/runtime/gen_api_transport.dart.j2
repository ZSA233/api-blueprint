    super.headers = const {},
  });
}

typedef SocketUnsubscribe = void Function();
typedef SocketMessageHandler<T> = void Function(T message);
typedef SocketCloseHandler<T> = void Function(T close);

abstract interface class ApiStreamBridge<Recv, Close> {
  String get routeId;
  Future<void> get ready;
  SocketUnsubscribe onMessage(SocketMessageHandler<Recv> listener);
  SocketUnsubscribe onClose(SocketCloseHandler<Close> listener);
  Future<void> close([int? code, String? reason]);
}

abstract interface class ApiChannelBridge<Recv, Send, Close> implements ApiStreamBridge<Recv, Close> {
  Future<void> send(Send message);
}

abstract interface class ApiTransport {
  Future<T> request<T>(ApiRequest<T> request);
  ApiStreamBridge<Recv, Close> openStream<Recv, Close>(StreamConnectOptions<Recv, Close> options);
  ApiChannelBridge<Recv, Send, Close> openChannel<Recv, Send, Close>(
    ChannelConnectOptions<Recv, Send, Close> options,
  );
}

T decodeApiResponse<T>(Object? payload, ApiRequest<T> request) {
  if (request.responseMediaType != 'application/json') {
    return request.decode(payload);
  }
  final unwrapped = unwrapResponseEnvelope(payload, request.responseEnvelope, request.routeId);
  return request.decode(unwrapped);
}

Uint8List apiBlueprintReadBytes(Object? value) {
  if (value is ApiBinaryPayload) {
    return value.bytes;
  }
  if (value is Uint8List) {
    return value;
  }
  if (value is List<int>) {
    return Uint8List.fromList(value);
  }
  if (value is List) {
    return Uint8List.fromList(value.map((item) => apiBlueprintReadInt(item) ?? 0).toList());
  }
  return Uint8List(0);
}

ApiRawResponse apiBlueprintRawResponse(
  Object? value, {
  String defaultContentType = 'application/octet-stream',
  String defaultFilename = '',
}) {
  if (value is ApiBinaryPayload) {
    return ApiRawResponse(
      body: value.bytes,
      contentType: value.contentType(defaultContentType),
      filename: value.filename(defaultFilename),
      headers: value.headers,
    );
  }
  return ApiRawResponse(body: apiBlueprintReadBytes(value), contentType: defaultContentType, filename: defaultFilename);
}

ApiStreamResponse apiBlueprintStreamResponse(
  Object? value, {
  String defaultContentType = 'application/octet-stream',
}) {
  if (value is ApiBinaryPayload) {
    return ApiStreamResponse(body: value.bytes, contentType: value.contentType(defaultContentType), headers: value.headers);
  }
  return ApiStreamResponse(body: apiBlueprintReadBytes(value), contentType: defaultContentType);
}

Object? unwrapResponseEnvelope(Object? payload, ApiResponseEnvelope envelope, String routeId) {
  if (envelope.kind == 'none') {
    return payload;
  }
  final root = apiBlueprintReadObject(payload);
  if (envelope.kind == 'code_message_data') {
    final code = apiBlueprintReadInt(root[envelope.fields.code]) ?? 0;
    if (code == envelope.successCode) {
      return root[envelope.fields.data];
    }
    throw ApiError(lookupApiError(_codeMessagePayload(root, envelope, routeId)), routeId: routeId, raw: payload);
  }
  if (envelope.kind == 'ok_data_error') {
    final ok = apiBlueprintReadBool(root[envelope.fields.ok]) ?? false;
    if (ok) {
      return root[envelope.fields.data];
    }
    throw ApiError(
      lookupApiError(ApiErrorPayload.fromJson(root[envelope.fields.error], routeId: routeId)),
      routeId: routeId,
      raw: payload,
    );
  }
  return payload;
}

ApiErrorPayload extractApiErrorPayload(Object? payload, String routeId, ApiResponseEnvelope envelope) {
  final root = apiBlueprintReadObject(payload);
  if (envelope.kind == 'code_message_data') {
    return _codeMessagePayload(root, envelope, routeId);
  }
  final nested = root[envelope.fields.error] ?? root['error'] ?? payload;
  return ApiErrorPayload.fromJson(nested, routeId: routeId);
}

ApiErrorPayload _codeMessagePayload(Map<String, Object?> root, ApiResponseEnvelope envelope, String routeId) {
  final nested = ApiErrorPayload.fromJson(root[envelope.fields.error], routeId: routeId);
  return ApiErrorPayload(
    id: nested.id,
    group: nested.group,
    key: nested.key,
    code: nested.code == 0 ? apiBlueprintReadInt(root[envelope.fields.code]) ?? 0 : nested.code,
    message: nested.message.isEmpty ? apiBlueprintReadString(root[envelope.fields.message]) ?? '' : nested.message,
    toast: nested.toast,
    routeId: routeId,
  );
}
