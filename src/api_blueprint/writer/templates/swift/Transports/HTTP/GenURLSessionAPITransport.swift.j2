import Foundation
#if canImport(FoundationNetworking)
import FoundationNetworking
#endif

public final class URLSessionAPITransport: APITransport {
    public let config: HTTPAPIConfig

    public init(config: HTTPAPIConfig = HTTPAPIConfig()) {
        self.config = config
    }

    public func request<Response>(_ request: APIRequest<Response>) async throws -> Response {
        let built = try buildRequest(request)
        defer { built.cleanup() }
{% if writer.modern_runtime %}
        if request.responseKind == "byte_stream" {
            let (bytes, response) = try await config.session.bytes(for: built.request)
            guard let httpResponse = response as? HTTPURLResponse else {
                throw APIDecodeError.invalidResponse("expected HTTP response")
            }
            if httpResponse.statusCode >= 400 || isJSONResponse(httpResponse) {
                let data = try await collectLimitedBytes(bytes, limit: config.maxErrorBodyBytes)
                try validateStatus(httpResponse, body: data, routeID: request.routeID, envelope: request.responseEnvelope)
                if isJSONResponse(httpResponse) {
                    try validateEnvelopeStatus(data, response: httpResponse, routeID: request.routeID, envelope: request.responseEnvelope)
                }
                let stream = singleDataStream(data)
                return try request.decode(streamResponse(stream, response: httpResponse, defaultContentType: request.responseMediaType))
            }
            let stream = chunkedByteStream(bytes)
            return try request.decode(streamResponse(stream, response: httpResponse, defaultContentType: request.responseMediaType))
        }
        let (data, response) = try await config.session.data(for: built.request)
{% else %}
        let (data, response) = try await performCompatDataTask(built.request)
{% endif %}
        guard let httpResponse = response as? HTTPURLResponse else {
            throw APIDecodeError.invalidResponse("expected HTTP response")
        }
        try validateStatus(httpResponse, body: data, routeID: request.routeID, envelope: request.responseEnvelope)

        if request.responseKind == "bytes" || request.responseKind == "file" {
            if isJSONResponse(httpResponse) {
                try validateEnvelopeStatus(data, response: httpResponse, routeID: request.routeID, envelope: request.responseEnvelope)
            }
            return try request.decode(rawResponse(data, response: httpResponse, defaultContentType: request.responseMediaType))
        }
        if request.responseKind == "byte_stream" {
            if isJSONResponse(httpResponse) {
                try validateEnvelopeStatus(data, response: httpResponse, routeID: request.routeID, envelope: request.responseEnvelope)
            }
            let stream = chunkedDataStream(data)
            return try request.decode(streamResponse(stream, response: httpResponse, defaultContentType: request.responseMediaType))
        }
        if request.responseKind == "binary_schema" {
            return try request.decode(data)
        }
        if !isJSONResponse(httpResponse) {
            return try request.decode(String(data: data, encoding: .utf8) ?? "")
        }
        return try decodeJSONResponse(request, data: data)
    }

    public func openStream<Recv, Close>(_ options: APIStreamConnectOptions<Recv, Close>) throws -> APIStreamBridge<Recv, Close> {
        var request = try buildConnectionRequest(path: options.path, query: options.query, headers: options.headers)
        request.httpMethod = "GET"
        request.setValue("text/event-stream", forHTTPHeaderField: "Accept")
        return apiHTTPEventStreamBridge(
            routeID: options.routeID,
            streamBufferLimit: config.streamBufferLimit,
            maxSSEEventBytes: config.maxSSEEventBytes,
            start: { onResponse, onData, onComplete in
{% if writer.modern_runtime %}
                self.performModernEventStreamTask(request, onResponse: onResponse, onData: onData, onComplete: onComplete)
{% else %}
                self.performCompatEventStreamTask(request, onResponse: onResponse, onData: onData, onComplete: onComplete)
{% endif %}
            },
            decodeMessage: options.decodeMessage,
            decodeClose: options.decodeClose
        )
    }

    public func openChannel<Recv, Send, Close>(_ options: APIChannelConnectOptions<Recv, Send, Close>) throws -> APIChannelBridge<Recv, Send, Close> {
        let request = try buildWebSocketRequest(path: options.path, query: options.query, headers: options.headers, protocols: options.protocols)
        let socket = config.session.webSocketTask(with: request)
        return apiHTTPWebSocketBridge(
            routeID: options.routeID,
            socket: socket,
            coding: config.coding,
            streamBufferLimit: config.streamBufferLimit,
            maxWebSocketMessageBytes: config.maxWebSocketMessageBytes,
            decodeMessage: options.decodeMessage,
            encodeMessage: options.encodeMessage,
            decodeClose: options.decodeClose
        )
    }

    private func buildRequest<Response>(_ request: APIRequest<Response>) throws -> APIBuiltRequest {
        let url = try buildURL(path: request.path, query: request.query)
        var urlRequest = URLRequest(url: url)
        urlRequest.httpMethod = request.method
        try applyHeaders(config.defaultHeaders, to: &urlRequest)
        try applyHeaders(request.options.headers, to: &urlRequest)
        if let timeout = request.options.timeout ?? config.timeout {
            urlRequest.timeoutInterval = timeout
        }
        var cleanup: () -> Void = {}
        if let json = request.json {
            urlRequest.setValue("application/json", forHTTPHeaderField: "Content-Type")
            urlRequest.httpBody = try json(config.coding)
        } else if let form = request.form {
            urlRequest.setValue("application/x-www-form-urlencoded", forHTTPHeaderField: "Content-Type")
            urlRequest.httpBody = encodeForm(form).data(using: .utf8)
        } else if let multipart = request.multipart {
            let boundary = "api-blueprint-\(UUID().uuidString)"
            urlRequest.setValue("multipart/form-data; boundary=\(boundary)", forHTTPHeaderField: "Content-Type")
            let body = try encodeMultipart(multipart, boundary: boundary)
            if let data = body.data {
                urlRequest.httpBody = data
            } else if let fileURL = body.fileURL {
                urlRequest.httpBodyStream = InputStream(url: fileURL)
                cleanup = body.cleanup
            }
        } else if let binary = request.binary {
            urlRequest.setValue(request.binaryContentType ?? "application/octet-stream", forHTTPHeaderField: "Content-Type")
            urlRequest.httpBody = binary
        }
        if urlRequest.value(forHTTPHeaderField: "Accept") == nil {
            urlRequest.setValue("application/json", forHTTPHeaderField: "Accept")
        }
        return APIBuiltRequest(request: urlRequest, cleanup: cleanup)
    }

    private func buildURL(path: String, query: [URLQueryItem]) throws -> URL {
        let normalizedPath = path.hasPrefix("/") ? path : "/\(path)"
        guard let base = config.baseURL ?? URL(string: "http://localhost") else {
            throw APITransportError.invalidURL("http://localhost")
        }
        let raw = base.absoluteString.trimmingCharacters(in: CharacterSet(charactersIn: "/")) + normalizedPath
        guard var components = URLComponents(string: raw) else {
            throw APITransportError.invalidURL(raw)
        }
        let existing = components.queryItems ?? []
        components.queryItems = (existing + query).filter { $0.value != nil }
        guard let url = components.url else {
            throw APITransportError.invalidURL(raw)
        }
        return url
    }

    private func buildConnectionRequest(path: String, query: [URLQueryItem], headers: [String: String]) throws -> URLRequest {
        var request = URLRequest(url: try buildURL(path: path, query: query))
        try applyHeaders(config.defaultHeaders, to: &request)
        try applyHeaders(headers, to: &request)
        if let timeout = config.timeout {
            request.timeoutInterval = timeout
        }
        return request
    }

    private func buildWebSocketRequest(path: String, query: [URLQueryItem], headers: [String: String], protocols: [String]) throws -> URLRequest {
        let httpURL = try buildURL(path: path, query: query)
        guard var components = URLComponents(url: httpURL, resolvingAgainstBaseURL: false) else {
            throw APITransportError.invalidURL(httpURL.absoluteString)
        }
        if components.scheme == "http" {
            components.scheme = "ws"
        } else if components.scheme == "https" {
            components.scheme = "wss"
        }
        guard let url = components.url else {
            throw APITransportError.invalidURL(httpURL.absoluteString)
        }
        var request = URLRequest(url: url)
        try applyHeaders(config.defaultHeaders, to: &request)
        try applyHeaders(headers, to: &request)
        if !protocols.isEmpty {
            let value = protocols.joined(separator: ", ")
            try validateHeaderValue(value)
            request.setValue(value, forHTTPHeaderField: "Sec-WebSocket-Protocol")
        }
        if let timeout = config.timeout {
            request.timeoutInterval = timeout
        }
        return request
    }

{% if writer.modern_runtime %}
    private func performModernEventStreamTask(
        _ request: URLRequest,
        onResponse: @escaping (HTTPURLResponse) throws -> Void,
        onData: @escaping (Data) -> Void,
        onComplete: @escaping (Error?) -> Void
    ) -> APIHTTPCancellable {
        let task = Task {
            do {
                let (bytes, response) = try await config.session.bytes(for: request)
                guard let httpResponse = response as? HTTPURLResponse else {
                    throw APIDecodeError.invalidResponse("expected HTTP response")
                }
                try onResponse(httpResponse)
                var chunk = Data()
                chunk.reserveCapacity(max(1, config.byteStreamChunkSize))
                for try await byte in bytes {
                    chunk.append(byte)
                    if chunk.count >= max(1, config.byteStreamChunkSize) {
                        onData(chunk)
                        chunk.removeAll(keepingCapacity: true)
                    }
                }
                if !chunk.isEmpty {
                    onData(chunk)
                }
                onComplete(nil)
            } catch {
                onComplete(error)
            }
        }
        return APIHTTPCancellable {
            task.cancel()
        }
    }

{% endif %}
{% if not writer.modern_runtime %}
    private func performCompatDataTask(_ request: URLRequest) async throws -> (Data, URLResponse) {
        try await withCheckedThrowingContinuation { continuation in
            let task = config.session.dataTask(with: request) { data, response, error in
                if let error {
                    continuation.resume(throwing: error)
                    return
                }
                guard let response else {
                    continuation.resume(throwing: APIDecodeError.invalidResponse("missing HTTP response"))
                    return
                }
                continuation.resume(returning: (data ?? Data(), response))
            }
            task.resume()
        }
    }

    private func performCompatEventStreamTask(
        _ request: URLRequest,
        onResponse: @escaping (HTTPURLResponse) throws -> Void,
        onData: @escaping (Data) -> Void,
        onComplete: @escaping (Error?) -> Void
    ) -> APIHTTPCancellable {
        let bridge = APIHTTPCompatEventStreamTask(
            request: request,
            configuration: config.session.configuration,
            onResponse: onResponse,
            onData: onData,
            onComplete: onComplete
        )
        bridge.resume()
        return APIHTTPCancellable {
            bridge.cancel()
        }
    }

{% endif %}
    private func decodeJSONResponse<Response>(_ request: APIRequest<Response>, data: Data) throws -> Response {
        do {
            return try request.decodeData(data, request.responseEnvelope, config.coding)
        } catch let error as APIError {
            throw APIError(
                payload: error.payload,
                routeID: error.routeID.isEmpty ? request.routeID : error.routeID,
                raw: error.raw ?? String(data: data, encoding: .utf8) ?? ""
            )
        }
    }

    private func validateStatus(_ response: HTTPURLResponse, body: Data, routeID: String, envelope: APIResponseEnvelope) throws {
        if response.statusCode < 400 {
            return
        }
        if body.count > config.maxErrorBodyBytes {
            throw APITransportError.payloadTooLarge(kind: "error", limit: config.maxErrorBodyBytes)
        }
        let text = String(data: body, encoding: .utf8) ?? ""
        if let json = try? JSONSerialization.jsonObject(with: body, options: []) {
            throw APIError(payload: apiErrorPayload(from: json, routeID: routeID), routeID: routeID, raw: text)
        }
        throw APIHTTPError(statusCode: response.statusCode, body: text)
    }

    private func validateEnvelopeStatus(_ data: Data, response: HTTPURLResponse, routeID: String, envelope: APIResponseEnvelope) throws {
        guard isJSONResponse(response), !data.isEmpty else {
            return
        }
        let json = try JSONSerialization.jsonObject(with: data, options: [])
        _ = try unwrapResponseEnvelope(json, body: data, envelope: envelope, routeID: routeID)
    }

    private func unwrapResponseEnvelope(_ value: Any?, body: Data, envelope: APIResponseEnvelope, routeID: String) throws -> Any? {
        do {
            return try apiUnwrapResponseEnvelope(value, envelope: envelope, routeID: routeID)
        } catch let error as APIError {
            throw APIError(
                payload: error.payload,
                routeID: error.routeID.isEmpty ? routeID : error.routeID,
                raw: String(data: body, encoding: .utf8) ?? ""
            )
        }
    }

    private func isJSONResponse(_ response: HTTPURLResponse) -> Bool {
        let contentType = response.value(forHTTPHeaderField: "Content-Type")?.split(separator: ";").first?.lowercased() ?? ""
        return contentType == "application/json" || contentType.hasSuffix("+json")
    }

    private func rawResponse(_ data: Data, response: HTTPURLResponse, defaultContentType: String) -> APIRawResponse {
        APIRawResponse(
            body: data,
            headers: headers(response),
            statusCode: response.statusCode,
            contentType: response.value(forHTTPHeaderField: "Content-Type") ?? defaultContentType,
            contentDisposition: response.value(forHTTPHeaderField: "Content-Disposition") ?? "",
            filename: filename(response)
        )
    }

    private func streamResponse(_ stream: AsyncThrowingStream<Data, Error>, response: HTTPURLResponse, defaultContentType: String) -> APIStreamResponse {
        APIStreamResponse(
            body: stream,
            headers: headers(response),
            statusCode: response.statusCode,
            contentType: response.value(forHTTPHeaderField: "Content-Type") ?? defaultContentType,
            contentDisposition: response.value(forHTTPHeaderField: "Content-Disposition") ?? "",
            filename: filename(response)
        )
    }

    private func headers(_ response: HTTPURLResponse) -> [String: String] {
        var result: [String: String] = [:]
        for (name, value) in response.allHeaderFields {
            result[String(describing: name)] = String(describing: value)
        }
        return result
    }

    private func filename(_ response: HTTPURLResponse) -> String? {
        guard let disposition = response.value(forHTTPHeaderField: "Content-Disposition") else {
            return nil
        }
        for part in disposition.split(separator: ";") {
            let trimmed = part.trimmingCharacters(in: .whitespaces)
            if trimmed.lowercased().hasPrefix("filename*=") {
                let raw = String(trimmed.dropFirst("filename*=".count)).trimmingCharacters(in: CharacterSet(charactersIn: "\""))
                return decodeExtendedFilename(raw) ?? raw
            }
        }
        for part in disposition.split(separator: ";") {
            let trimmed = part.trimmingCharacters(in: .whitespaces)
            if trimmed.lowercased().hasPrefix("filename=") {
                return String(trimmed.dropFirst("filename=".count)).trimmingCharacters(in: CharacterSet(charactersIn: "\""))
            }
        }
        return nil
    }

    private func decodeExtendedFilename(_ raw: String) -> String? {
        let value = raw.trimmingCharacters(in: CharacterSet(charactersIn: "\""))
        if let marker = value.range(of: "''") {
            let encoded = String(value[marker.upperBound...])
            return encoded.removingPercentEncoding ?? encoded
        }
        return value.removingPercentEncoding
    }

    private func encodeForm(_ form: [String: String?]) -> String {
        form.compactMap { name, value in
            guard let value else {
                return nil
            }
            return "\(escapeFormComponent(name))=\(escapeFormComponent(value))"
        }.joined(separator: "&")
    }

    private func escapeFormComponent(_ value: String) -> String {
        var allowed = CharacterSet.alphanumerics
        allowed.insert(charactersIn: "-._~")
        return value.addingPercentEncoding(withAllowedCharacters: allowed) ?? value
    }

    private func applyHeaders(_ headers: [String: String], to request: inout URLRequest) throws {
        for (name, value) in headers {
            try validateHeaderValue(name)
            try validateHeaderValue(value)
            request.setValue(value, forHTTPHeaderField: name)
        }
    }

    private func validateHeaderValue(_ value: String) throws {
        if value.contains("\r") || value.contains("\n") {
            throw APITransportError.invalidHeaderValue(value)
        }
    }

    private func encodeMultipart(_ fields: [String: Any?], boundary: String) throws -> APIMultipartBody {
        if fieldsContainsFileURL(fields) {
            return try encodeMultipartToTemporaryFile(fields, boundary: boundary)
        }
        var data = Data()
        try writeMultipartParts(fields, boundary: boundary) { chunk in
            data.append(chunk)
        }
        if data.count > config.multipartMemoryThreshold {
            return try writeTemporaryBody(data)
        }
        return APIMultipartBody(data: data)
    }

    private func fieldsContainsFileURL(_ fields: [String: Any?]) -> Bool {
        fields.values.contains { value in
            guard let file = value as? APIFilePart else {
                return false
            }
            return file.fileURL != nil
        }
    }

    private func writeMultipartParts(
        _ fields: [String: Any?],
        boundary: String,
        append: (Data) throws -> Void
    ) throws {
        for (name, value) in fields {
            guard let value else {
                continue
            }
            try validateHeaderValue(name)
            try append(Data("--\(boundary)\r\n".utf8))
            if let file = value as? APIFilePart {
                try validateHeaderValue(file.filename)
                try validateHeaderValue(file.contentType)
                let disposition = multipartFileDisposition(name: name, filename: file.filename)
                try append(Data("Content-Disposition: \(disposition)\r\n".utf8))
                try append(Data("Content-Type: \(file.contentType)\r\n\r\n".utf8))
                if let data = file.data {
                    try append(data)
                } else if let fileURL = file.fileURL {
                    try appendFile(fileURL, append: append)
                }
                try append(Data("\r\n".utf8))
            } else {
                try append(Data("Content-Disposition: form-data; name=\"\(quoteHeaderValue(name))\"\r\n\r\n".utf8))
                try append(Data(String(describing: value).utf8))
                try append(Data("\r\n".utf8))
            }
        }
        try append(Data("--\(boundary)--\r\n".utf8))
    }

    private func multipartFileDisposition(name: String, filename: String) -> String {
        var disposition = "form-data; name=\"\(quoteHeaderValue(name))\"; filename=\"\(quoteHeaderValue(filename))\""
        if !filename.unicodeScalars.allSatisfy({ $0.isASCII }) {
            disposition += "; filename*=UTF-8''\(escapeRFC5987(filename))"
        }
        return disposition
    }

    private func quoteHeaderValue(_ value: String) -> String {
        value.replacingOccurrences(of: "\\", with: "\\\\").replacingOccurrences(of: "\"", with: "\\\"")
    }

    private func escapeRFC5987(_ value: String) -> String {
        var allowed = CharacterSet.alphanumerics
        allowed.insert(charactersIn: "-._~")
        return value.addingPercentEncoding(withAllowedCharacters: allowed) ?? value
    }

    private func appendFile(_ fileURL: URL, append: (Data) throws -> Void) throws {
        do {
            let handle = try FileHandle(forReadingFrom: fileURL)
            defer { try? handle.close() }
            while true {
                let chunk = handle.readData(ofLength: max(1, config.byteStreamChunkSize))
                if chunk.isEmpty {
                    break
                }
                try append(chunk)
            }
        } catch {
            throw APITransportError.fileReadFailed(fileURL.path)
        }
    }

    private func encodeMultipartToTemporaryFile(_ fields: [String: Any?], boundary: String) throws -> APIMultipartBody {
        let tempURL = FileManager.default.temporaryDirectory.appendingPathComponent("api-blueprint-\(UUID().uuidString).multipart")
        _ = FileManager.default.createFile(atPath: tempURL.path, contents: nil)
        let handle = try FileHandle(forWritingTo: tempURL)
        do {
            try writeMultipartParts(fields, boundary: boundary) { chunk in
                try handle.write(contentsOf: chunk)
            }
            try? handle.close()
        } catch {
            try? handle.close()
            try? FileManager.default.removeItem(at: tempURL)
            throw error
        }
        return APIMultipartBody(fileURL: tempURL, cleanup: {
            try? FileManager.default.removeItem(at: tempURL)
        })
    }

    private func writeTemporaryBody(_ data: Data) throws -> APIMultipartBody {
        let tempURL = FileManager.default.temporaryDirectory.appendingPathComponent("api-blueprint-\(UUID().uuidString).body")
        try data.write(to: tempURL)
        return APIMultipartBody(fileURL: tempURL, cleanup: {
            try? FileManager.default.removeItem(at: tempURL)
        })
    }

{% if writer.modern_runtime %}
    private func collectLimitedBytes<Bytes: AsyncSequence>(_ bytes: Bytes, limit: Int) async throws -> Data where Bytes.Element == UInt8 {
        var data = Data()
        for try await byte in bytes {
            if data.count >= limit {
                throw APITransportError.payloadTooLarge(kind: "error", limit: limit)
            }
            data.append(byte)
        }
        return data
    }

    private func chunkedByteStream<Bytes: AsyncSequence>(_ bytes: Bytes) -> AsyncThrowingStream<Data, Error> where Bytes.Element == UInt8 {
        AsyncThrowingStream<Data, Error>(bufferingPolicy: .bufferingNewest(max(1, config.streamBufferLimit))) { continuation in
            Task {
                do {
                    var chunk = Data()
                    chunk.reserveCapacity(max(1, config.byteStreamChunkSize))
                    for try await byte in bytes {
                        chunk.append(byte)
                        if chunk.count >= max(1, config.byteStreamChunkSize) {
                            continuation.yield(chunk)
                            chunk.removeAll(keepingCapacity: true)
                        }
                    }
                    if !chunk.isEmpty {
                        continuation.yield(chunk)
                    }
                    continuation.finish()
                } catch {
                    continuation.finish(throwing: error)
                }
            }
        }
    }

{% endif %}
    private func singleDataStream(_ data: Data) -> AsyncThrowingStream<Data, Error> {
        AsyncThrowingStream<Data, Error>(bufferingPolicy: .bufferingNewest(1)) { continuation in
            continuation.yield(data)
            continuation.finish()
        }
    }

    private func chunkedDataStream(_ data: Data) -> AsyncThrowingStream<Data, Error> {
        AsyncThrowingStream<Data, Error>(bufferingPolicy: .bufferingNewest(max(1, config.streamBufferLimit))) { continuation in
            if data.isEmpty {
                continuation.finish()
                return
            }
            var offset = 0
            let chunkSize = max(1, config.byteStreamChunkSize)
            while offset < data.count {
                let end = min(offset + chunkSize, data.count)
                continuation.yield(data.subdata(in: offset..<end))
                offset = end
            }
            continuation.finish()
        }
    }
}

private struct APIBuiltRequest {
    var request: URLRequest
    var cleanup: () -> Void = {}
}

private struct APIMultipartBody {
    var data: Data?
    var fileURL: URL?
    var cleanup: () -> Void

    init(data: Data) {
        self.data = data
        self.fileURL = nil
        self.cleanup = {}
    }

    init(fileURL: URL, cleanup: @escaping () -> Void) {
        self.data = nil
        self.fileURL = fileURL
        self.cleanup = cleanup
    }
}

{% if not writer.modern_runtime %}
private final class APIHTTPCompatEventStreamTask: NSObject, URLSessionDataDelegate {
    private let lock = NSLock()
    private let onResponse: (HTTPURLResponse) throws -> Void
    private let onData: (Data) -> Void
    private let onComplete: (Error?) -> Void
    private var session: URLSession?
    private var task: URLSessionDataTask?
    private var didComplete = false

    init(
        request: URLRequest,
        configuration: URLSessionConfiguration,
        onResponse: @escaping (HTTPURLResponse) throws -> Void,
        onData: @escaping (Data) -> Void,
        onComplete: @escaping (Error?) -> Void
    ) {
        self.onResponse = onResponse
        self.onData = onData
        self.onComplete = onComplete
        super.init()
        let queue = OperationQueue()
        queue.maxConcurrentOperationCount = 1
        let session = URLSession(configuration: configuration, delegate: self, delegateQueue: queue)
        self.session = session
        self.task = session.dataTask(with: request)
    }

    func resume() {
        task?.resume()
    }

    func cancel() {
        lock.lock()
        if didComplete {
            lock.unlock()
            return
        }
        didComplete = true
        let task = self.task
        let session = self.session
        self.task = nil
        self.session = nil
        lock.unlock()
        task?.cancel()
        session?.invalidateAndCancel()
    }

    func urlSession(
        _ session: URLSession,
        dataTask: URLSessionDataTask,
        didReceive response: URLResponse,
        completionHandler: @escaping (URLSession.ResponseDisposition) -> Void
    ) {
        guard let httpResponse = response as? HTTPURLResponse else {
            completionHandler(.cancel)
            complete(APIDecodeError.invalidResponse("expected HTTP response"))
            return
        }
        do {
            try onResponse(httpResponse)
            completionHandler(.allow)
        } catch {
            completionHandler(.cancel)
            complete(error)
        }
    }

    func urlSession(_ session: URLSession, dataTask: URLSessionDataTask, didReceive data: Data) {
        lock.lock()
        let active = !didComplete
        lock.unlock()
        if active {
            onData(data)
        }
    }

    func urlSession(_ session: URLSession, task: URLSessionTask, didCompleteWithError error: Error?) {
        complete(error)
    }

    func urlSession(_ session: URLSession, didBecomeInvalidWithError error: Error?) {
        if let error {
            complete(error)
        }
    }

    private func complete(_ error: Error?) {
        lock.lock()
        if didComplete {
            lock.unlock()
            return
        }
        didComplete = true
        let session = self.session
        self.task = nil
        self.session = nil
        lock.unlock()
        if error == nil {
            session?.finishTasksAndInvalidate()
        } else {
            session?.invalidateAndCancel()
        }
        onComplete(error)
    }
}
{% endif %}
