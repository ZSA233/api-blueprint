    public init(code: String = "code", message: String = "message", data: String = "data", error: String = "error", ok: String = "ok") {
        self.code = code
        self.message = message
        self.data = data
        self.error = error
        self.ok = ok
    }
}

public protocol APIWireValue {
    var apiWireString: String { get }
}

public enum APIJSONValue: Codable, Sendable, Equatable {
    case null
    case bool(Bool)
    case number(Double)
    case string(String)
    case array([APIJSONValue])
    case object([String: APIJSONValue])

    public init(from decoder: Decoder) throws {
        let container = try decoder.singleValueContainer()
        if container.decodeNil() {
            self = .null
        } else if let value = try? container.decode(Bool.self) {
            self = .bool(value)
        } else if let value = try? container.decode(Double.self) {
            self = .number(value)
        } else if let value = try? container.decode(String.self) {
            self = .string(value)
        } else if let value = try? container.decode([APIJSONValue].self) {
            self = .array(value)
        } else {
            self = .object(try container.decode([String: APIJSONValue].self))
        }
    }

    public func encode(to encoder: Encoder) throws {
        var container = encoder.singleValueContainer()
        switch self {
        case .null:
            try container.encodeNil()
        case .bool(let value):
            try container.encode(value)
        case .number(let value):
            try container.encode(value)
        case .string(let value):
            try container.encode(value)
        case .array(let value):
            try container.encode(value)
        case .object(let value):
            try container.encode(value)
        }
    }
}

public enum APIDecodeError: Error, CustomStringConvertible {
    case expectedValue(String)
    case invalidJSON
    case invalidResponse(String)

    public var description: String {
        switch self {
        case .expectedValue(let type):
            return "expected API value \(type)"
        case .invalidJSON:
            return "invalid API JSON"
        case .invalidResponse(let message):
            return message
        }
    }
}

public func apiDecodeCoerceString<K: CodingKey>(
    from container: KeyedDecodingContainer<K>,
    forKey key: K
) throws -> String {
    if let value = try? container.decode(String.self, forKey: key) {
        return value
    }
    if let value = try? container.decode(Int.self, forKey: key) {
        return String(value)
    }
    throw DecodingError.typeMismatch(
        String.self,
        DecodingError.Context(
            codingPath: container.codingPath + [key],
            debugDescription: "expected string or integer"
        )
    )
}

public func apiDecodeCoerceStringIfPresent<K: CodingKey>(
    from container: KeyedDecodingContainer<K>,
    forKey key: K
) throws -> String? {
    if !container.contains(key) {
        return nil
    }
    if try container.decodeNil(forKey: key) {
        return nil
    }
    return try apiDecodeCoerceString(from: container, forKey: key)
}

public func apiDecodeCoerceString(from decoder: Decoder) throws -> String {
    let container = try decoder.singleValueContainer()
    if let value = try? container.decode(String.self) {
        return value
    }
    if let value = try? container.decode(Int.self) {
        return String(value)
    }
    throw DecodingError.typeMismatch(
        String.self,
        DecodingError.Context(
            codingPath: decoder.codingPath,
            debugDescription: "expected string or integer"
        )
    )
}

public func apiDecodeCoerceStringArray<K: CodingKey>(
    from container: KeyedDecodingContainer<K>,
    forKey key: K
) throws -> [String] {
    let decoder = try container.superDecoder(forKey: key)
    return try apiDecodeCoerceStringArray(from: decoder)
}

public func apiDecodeCoerceStringArrayIfPresent<K: CodingKey>(
    from container: KeyedDecodingContainer<K>,
    forKey key: K
) throws -> [String]? {
    if !container.contains(key) {
        return nil
    }
    if try container.decodeNil(forKey: key) {
        return nil
    }
    return try apiDecodeCoerceStringArray(from: container, forKey: key)
}

public func apiDecodeCoerceStringArray(from decoder: Decoder) throws -> [String] {
    var container = try decoder.unkeyedContainer()
    var values: [String] = []
    while !container.isAtEnd {
        values.append(try apiDecodeCoerceString(from: container.superDecoder()))
    }
    return values
}

public func apiEncodeJSONData<T: Encodable>(_ value: T, coding: APICodingConfig) throws -> Data {
    try coding.makeJSONEncoder().encode(value)
}

public func apiEncodeJSONObject<T: Encodable>(_ value: T, coding: APICodingConfig = APICodingConfig()) throws -> Any? {
    let data = try apiEncodeJSONData(value, coding: coding)
    return try JSONSerialization.jsonObject(with: data, options: [])
}

public func apiDecodeResponse<T: Decodable>(
    _ type: T.Type,
    from data: Data,
    envelope: APIResponseEnvelope,
    routeID: String,
    coding: APICodingConfig
) throws -> T {
    if envelope.kind == "none" {
        return try coding.makeJSONDecoder().decode(T.self, from: data)
    }
    if envelope.kind == "code_message_data" {
        let response = try apiDecodeCodeMessageDataEnvelope(type, from: data, fields: envelope.fields, coding: coding)
        if response.code == nil || response.code == envelope.successCode {
            guard let value = response.data else {
                throw APIDecodeError.expectedValue(String(describing: type))
            }
            return value
        }
        throw APIError(payload: apiErrorPayload(from: apiJSONObject(data), routeID: routeID), routeID: routeID, raw: String(data: data, encoding: .utf8) ?? "")
    }
    if envelope.kind == "ok_data_error" {
        let response = try apiDecodeOkDataErrorEnvelope(type, from: data, fields: envelope.fields, coding: coding)
        if response.ok == false {
            throw APIError(payload: apiErrorPayload(from: apiJSONObject(data), routeID: routeID), routeID: routeID, raw: String(data: data, encoding: .utf8) ?? "")
        }
        guard let value = response.data else {
            throw APIDecodeError.expectedValue(String(describing: type))
        }
        return value
    }
    return try coding.makeJSONDecoder().decode(T.self, from: data)
}

public func apiDecodeValue<T: Decodable>(_ type: T.Type, from value: Any?, coding: APICodingConfig = APICodingConfig()) throws -> T {
    if let typed = value as? T {
        return typed
    }
    guard let value else {
        throw APIDecodeError.expectedValue(String(describing: type))
    }
    let data = try JSONSerialization.data(withJSONObject: value, options: [.fragmentsAllowed])
    return try coding.makeJSONDecoder().decode(T.self, from: data)
}

public func apiDecodeString(_ value: Any?) throws -> String {
    if let value = value as? String {
        return value
    }
    if let data = value as? Data {
        return String(data: data, encoding: .utf8) ?? ""
    }
    guard let value else {
        return ""
    }
    return String(describing: value)
}

public func apiDecodeData(_ value: Any?) throws -> Data {
    if let value = value as? Data {
        return value
    }
    if let raw = value as? APIRawResponse {
        return raw.body
    }
    throw APIDecodeError.expectedValue("Data")
}

public func apiDecodeRawResponse(_ value: Any?) throws -> APIRawResponse {
    if let value = value as? APIRawResponse {
        return value
    }
    throw APIDecodeError.expectedValue("APIRawResponse")
}

public func apiDecodeStreamResponse(_ value: Any?) throws -> APIStreamResponse {
    if let value = value as? APIStreamResponse {
        return value
    }
    throw APIDecodeError.expectedValue("APIStreamResponse")
}

public func apiBlueprintQueryValue(_ value: Any?) -> String? {
    guard let value else {
        return nil
    }
    if let wireValue = value as? APIWireValue {
        return wireValue.apiWireString
    }
    if let boolValue = value as? Bool {
        return boolValue ? "true" : "false"
    }
    if let value = value as? CustomStringConvertible {
        return value.description
    }
    if JSONSerialization.isValidJSONObject(value),
       let data = try? JSONSerialization.data(withJSONObject: value, options: []),
       let rendered = String(data: data, encoding: .utf8) {
        return rendered
    }
    return String(describing: value)
}

public func apiBlueprintFormFields<T: Encodable>(_ value: T) throws -> [String: String?] {
    let object = try apiEncodeJSONObject(value)
    guard let dictionary = object as? [String: Any?] else {
        return [:]
    }
    return dictionary.mapValues { apiBlueprintQueryValue($0) }
}

public func apiBlueprintMultipartFields<T: Encodable>(_ value: T) throws -> [String: Any?] {
    let object = try apiEncodeJSONObject(value)
    var fields = object as? [String: Any?] ?? [:]
    for child in Mirror(reflecting: value).children {
        guard let label = child.label,
              let file = apiBlueprintUnwrapFilePart(child.value) else {
            continue
        }
        for key in apiBlueprintMultipartFieldKeys(for: label) where fields.keys.contains(key) {
            fields[key] = file
            break
        }
    }
    return fields
}

private struct APIDecodedCodeMessageDataEnvelope<T: Decodable> {
    var code: Int?
    var data: T?
}

private struct APIDecodedOkDataErrorEnvelope<T: Decodable> {
    var ok: Bool?
    var data: T?
}

private struct APIDynamicCodingKey: CodingKey {
    var stringValue: String
    var intValue: Int?

    init(_ stringValue: String) {
        self.stringValue = stringValue
        self.intValue = nil
    }

    init?(stringValue: String) {
        self.init(stringValue)
    }

    init?(intValue: Int) {
        self.stringValue = String(intValue)
        self.intValue = intValue
    }
}

private func apiDecodeCodeMessageDataEnvelope<T: Decodable>(
    _ type: T.Type,
    from data: Data,
    fields: APIResponseEnvelopeFields,
    coding: APICodingConfig
) throws -> APIDecodedCodeMessageDataEnvelope<T> {
    let decoder = coding.makeJSONDecoder()
    let container = try decoder.decode(APIDynamicObject.self, from: data)
    return APIDecodedCodeMessageDataEnvelope(
        code: container.int(fields.code),
        data: try container.decodeIfPresent(type, for: fields.data, coding: coding)
    )
}

private func apiDecodeOkDataErrorEnvelope<T: Decodable>(
    _ type: T.Type,
    from data: Data,
    fields: APIResponseEnvelopeFields,
    coding: APICodingConfig
) throws -> APIDecodedOkDataErrorEnvelope<T> {
    let decoder = coding.makeJSONDecoder()
    let container = try decoder.decode(APIDynamicObject.self, from: data)
    return APIDecodedOkDataErrorEnvelope(
        ok: container.bool(fields.ok),
        data: try container.decodeIfPresent(type, for: fields.data, coding: coding)
    )
}

private struct APIDynamicObject: Decodable {
    private var values: [String: APIJSONValue]

    init(from decoder: Decoder) throws {
        values = try decoder.singleValueContainer().decode([String: APIJSONValue].self)
    }

    func int(_ key: String) -> Int? {
        guard let value = values[key] else {
            return nil
        }
        switch value {
        case .number(let value):
            return Int(value)
        case .string(let value):
            return Int(value)
        default:
            return nil
        }
    }

    func bool(_ key: String) -> Bool? {
        guard let value = values[key] else {
            return nil
        }
        switch value {
        case .bool(let value):
            return value
        default:
            return nil
        }
    }

    func decodeIfPresent<T: Decodable>(_ type: T.Type, for key: String, coding: APICodingConfig) throws -> T? {
        guard let value = values[key] else {
            return nil
        }
        if case .null = value {
            return nil
        }
        let data = try coding.makeJSONEncoder().encode(value)
        return try coding.makeJSONDecoder().decode(type, from: data)
    }
}

private func apiJSONObject(_ data: Data) -> Any? {
    try? JSONSerialization.jsonObject(with: data, options: [])
}

private func apiBlueprintUnwrapFilePart(_ value: Any) -> APIFilePart? {
    if let file = value as? APIFilePart {
        return file
    }
    let mirror = Mirror(reflecting: value)
    if mirror.displayStyle == .optional, let wrapped = mirror.children.first?.value {
        return apiBlueprintUnwrapFilePart(wrapped)
    }
    return nil
}

private func apiBlueprintMultipartFieldKeys(for label: String) -> [String] {
    var keys = [label]
    if label.hasSuffix("_") {
        keys.append(String(label.dropLast()))
    }
    let snake = apiBlueprintCamelToSnake(label)
    if !keys.contains(snake) {
        keys.append(snake)
    }
    return keys
}

private func apiBlueprintCamelToSnake(_ value: String) -> String {
    var result = ""
    for scalar in value.unicodeScalars {
        let character = Character(scalar)
        if CharacterSet.uppercaseLetters.contains(scalar) {
            if !result.isEmpty {
                result.append("_")
            }
            result.append(String(character).lowercased())
        } else {
            result.append(character)
        }
    }
    return result
}
