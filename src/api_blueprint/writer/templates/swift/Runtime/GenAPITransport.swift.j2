        self.encodeMessage = encodeMessage
        self.decodeClose = decodeClose
    }
}

public struct APIStreamBridge<Recv, Close> {
    public let routeID: String
    public let messages: AsyncThrowingStream<Recv, Error>
    public let closes: AsyncStream<Close>
    private let closeHandler: (Int?, String?) async -> Void

    public init(
        routeID: String,
        messages: AsyncThrowingStream<Recv, Error>,
        closes: AsyncStream<Close>,
        close: @escaping (Int?, String?) async -> Void
    ) {
        self.routeID = routeID
        self.messages = messages
        self.closes = closes
        self.closeHandler = close
    }

    public func close(code: Int? = nil, reason: String? = nil) async {
        await closeHandler(code, reason)
    }
}

public struct APIChannelBridge<Recv, Send, Close> {
    public let routeID: String
    public let messages: AsyncThrowingStream<Recv, Error>
    public let closes: AsyncStream<Close>
    private let sendHandler: (Send) async throws -> Void
    private let closeHandler: (Int?, String?) async -> Void

    public init(
        routeID: String,
        messages: AsyncThrowingStream<Recv, Error>,
        closes: AsyncStream<Close>,
        send: @escaping (Send) async throws -> Void,
        close: @escaping (Int?, String?) async -> Void
    ) {
        self.routeID = routeID
        self.messages = messages
        self.closes = closes
        self.sendHandler = send
        self.closeHandler = close
    }

    public func send(_ message: Send) async throws {
        try await sendHandler(message)
    }

    public func close(code: Int? = nil, reason: String? = nil) async {
        await closeHandler(code, reason)
    }
}

public struct APIFilePart: Codable, Sendable {
    public var filename: String
    public var contentType: String
    public var data: Data?
    public var fileURL: URL?

    public init(filename: String = "", contentType: String = "application/octet-stream", data: Data) {
        self.filename = filename
        self.contentType = contentType
        self.data = data
        self.fileURL = nil
    }

    public init(fileURL: URL, filename: String? = nil, contentType: String = "application/octet-stream") {
        self.filename = filename ?? fileURL.lastPathComponent
        self.contentType = contentType
        self.data = nil
        self.fileURL = fileURL
    }
}

