import Foundation

public struct APICodingConfig: Sendable {
    public var makeJSONEncoder: @Sendable () -> JSONEncoder
    public var makeJSONDecoder: @Sendable () -> JSONDecoder

    public init(
        makeJSONEncoder: @escaping @Sendable () -> JSONEncoder = { JSONEncoder() },
        makeJSONDecoder: @escaping @Sendable () -> JSONDecoder = { JSONDecoder() }
    ) {
        self.makeJSONEncoder = makeJSONEncoder
        self.makeJSONDecoder = makeJSONDecoder
    }
}

public struct APIRequestOptions {
    public var headers: [String: String]
    public var timeout: TimeInterval?

    public init(headers: [String: String] = [:], timeout: TimeInterval? = nil) {
        self.headers = headers
        self.timeout = timeout
    }
}

public struct APIRequest<Response> {
    public var routeID: String
    public var method: String
    public var path: String
    public var pathParams: [URLQueryItem]
    public var query: [URLQueryItem]
    public var options: APIRequestOptions
    public var json: ((APICodingConfig) throws -> Data)?
    public var form: [String: String?]?
    public var multipart: [String: Any?]?
    public var binary: Data?
    public var binaryContentType: String?
    public var responseMediaType: String
    public var responseKind: String
    public var responseEnvelope: APIResponseEnvelope
    public var decodeData: (Data, APIResponseEnvelope, APICodingConfig) throws -> Response
    public var decode: (Any?) throws -> Response

    public init(
        routeID: String,
        method: String,
        path: String,
        pathParams: [URLQueryItem] = [],
        query: [URLQueryItem] = [],
        options: APIRequestOptions = APIRequestOptions(),
        json: ((APICodingConfig) throws -> Data)? = nil,
        form: [String: String?]? = nil,
        multipart: [String: Any?]? = nil,
        binary: Data? = nil,
        binaryContentType: String? = nil,
        responseMediaType: String = "application/json",
        responseKind: String = "json",
        responseEnvelope: APIResponseEnvelope = APIResponseEnvelope(),
        decodeData: @escaping (Data, APIResponseEnvelope, APICodingConfig) throws -> Response = { _, _, _ in
            throw APIDecodeError.invalidResponse("missing API response data decoder")
        },
        decode: @escaping (Any?) throws -> Response
    ) {
        self.routeID = routeID
        self.method = method
        self.path = path
        self.pathParams = pathParams
        self.query = query
        self.options = options
        self.json = json
        self.form = form
        self.multipart = multipart
        self.binary = binary
        self.binaryContentType = binaryContentType
        self.responseMediaType = responseMediaType
        self.responseKind = responseKind
        self.responseEnvelope = responseEnvelope
        self.decodeData = decodeData
        self.decode = decode
    }
}

public protocol APITransport {
    func request<Response>(_ request: APIRequest<Response>) async throws -> Response
    func openStream<Recv, Close>(_ options: APIStreamConnectOptions<Recv, Close>) throws -> APIStreamBridge<Recv, Close>
    func openChannel<Recv, Send, Close>(_ options: APIChannelConnectOptions<Recv, Send, Close>) throws -> APIChannelBridge<Recv, Send, Close>
}

public enum APITransportError: Error, Sendable, CustomStringConvertible {
    case invalidURL(String)
    case payloadTooLarge(kind: String, limit: Int)
    case invalidHeaderValue(String)
    case fileReadFailed(String)

    public var description: String {
        switch self {
        case .invalidURL(let value):
            return "invalid API URL: \(value)"
        case .payloadTooLarge(let kind, let limit):
            return "\(kind) payload exceeds \(limit) bytes"
        case .invalidHeaderValue(let value):
            return "invalid HTTP header value: \(value)"
        case .fileReadFailed(let value):
            return "failed to read file: \(value)"
        }
    }
}

