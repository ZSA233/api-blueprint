        path: String,
        query: [URLQueryItem] = [],
        open: Any? = nil,
        headers: [String: String] = [:],
        protocols: [String] = [],
        delivery: String = "ordered",
        decodeMessage: @escaping (Any?) throws -> Recv,
        encodeMessage: @escaping (Send, APICodingConfig) throws -> Data,
        decodeClose: @escaping (Any?) throws -> Close
    ) {
        self.routeID = routeID
        self.connectionKind = connectionKind
        self.path = path
        self.query = query
        self.open = open
        self.headers = headers
        self.protocols = protocols
        self.delivery = delivery
