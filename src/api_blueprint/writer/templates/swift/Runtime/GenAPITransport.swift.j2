        fields: APIResponseEnvelopeFields = APIResponseEnvelopeFields()
    ) {
        self.name = name
        self.kind = kind
        self.errorIdentity = errorIdentity
        self.successCode = successCode
        self.successMessage = successMessage
        self.fields = fields
    }
}

