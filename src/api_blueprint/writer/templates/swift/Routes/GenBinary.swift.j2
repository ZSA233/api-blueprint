{% macro check_encode(field, receiver, int_expr, path) -%}
{% if field.const_value %}
{% if field.is_bytes or field.is_string or field.typ == "bool" %}
    try apiBinaryRequire({{ path | code_literal }}, {{ receiver }} == {{ field.default_expr }}, "const mismatch")
{% else %}
    try apiBinaryRequire({{ path | code_literal }}, {{ int_expr }} == {{ field.const_encode_expr(path) }}, "const mismatch")
{% endif %}
{% endif %}
{% if field.min_value and field.supports_numeric_rules %}
    try apiBinaryRequireRange({{ path | code_literal }}, {{ int_expr }}, {{ field.min_encode_expr(path) }}, {{ field.numeric_upper_bound_expr }})
{% endif %}
{% if field.max_value and field.supports_numeric_rules %}
    try apiBinaryRequireRange({{ path | code_literal }}, {{ int_expr }}, {{ field.numeric_lower_bound_expr }}, {{ field.max_encode_expr(path) }})
{% endif %}
{% if field.assert_value and field.supports_numeric_rules %}
    try apiBinaryRequire({{ path | code_literal }}, {{ int_expr }} == {{ field.assert_encode_expr(path) }}, "assert mismatch")
{% endif %}
{% if field.bitflags_zero_mask %}
    try apiBinaryRequire({{ path | code_literal }}, ({{ int_expr }} & {{ field.bitflags_zero_mask_expr }}) == 0, "reserved bits must be zero")
{% endif %}
{%- endmacro %}

