{% endif %}
{% elif field.is_scalar %}
{{ check_encode(field, receiver, field.write_int_expr, path) }}
{% if field.sizeof_value and object.has_field(field.sizeof_value) %}
    try apiBinaryRequireSize({{ (path ~ "." ~ field.sizeof_value) | code_literal }}, apiBinarySize(value.{{ field.sizeof_swift_name }}), {{ field.encode_count_value_expr(path ~ "." ~ field.sizeof_value) }})
{% endif %}
    try writer.{{ field.write_method }}({{ path | code_literal }}, {{ receiver }})
{% if field.can_store_var %}
    state.{{ field.swift_name }} = {{ field.write_int_expr }}
{% endif %}
{% else %}
    do {
