{%- endif %}
    {{ key }}({{ proto.enum_wire_literal(value) }}){% if not loop.last %},{% endif %}
{%- endfor %}
}
{%- if proto.enum_wire_type == 'int' %}

public object {{ proto.name }}Serializer : KSerializer<{{ proto.name }}> {
    public override val descriptor: SerialDescriptor = PrimitiveSerialDescriptor("{{ proto.name }}", PrimitiveKind.INT)

    public override fun serialize(encoder: Encoder, value: {{ proto.name }}): Unit {
        encoder.encodeInt(value.wireValue)
    }

    public override fun deserialize(decoder: Decoder): {{ proto.name }} {
        val wireValue = decoder.decodeInt()
        return {{ proto.name }}.values().firstOrNull { it.wireValue == wireValue }
            ?: throw SerializationException("Unknown {{ proto.name }} wire value: $wireValue")
    }
}
