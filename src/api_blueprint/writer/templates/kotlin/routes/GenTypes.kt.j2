{% for helper in group.message_helpers() %}

@Serializable
public data class {{ helper.name }}(
    public val type: String,
    public val data: JsonElement? = null,
)

public object {{ helper.variants_object }} {
{% for variant in helper.variants %}    public fun {{ variant.method_name }}(data: {{ variant.data_type }}): {{ helper.name }} =
        {{ helper.name }}({{ variant.key | tojson }}, ApiJson.encodeToJsonElement({{ variant.data_type }}.serializer(), data))

{% endfor %}}

public interface {{ helper.handlers_interface }}<R> {
{% for variant in helper.variants %}    public fun {{ variant.method_name }}(data: {{ variant.data_type }}, message: {{ helper.name }}): R
{% endfor %}}

public class {{ helper.dispatch_exception }}(
    public val kind: String,
    public val type: String,
    public val rawMessage: {{ helper.name }},
) : RuntimeException("unsupported {{ helper.name }} type $type")

public fun <R> {{ helper.dispatch_func }}(
    message: {{ helper.name }},
    handlers: {{ helper.handlers_interface }}<R>,
): R =
    when (message.type) {
{% for variant in helper.variants %}        {{ variant.key | tojson }} -> handlers.{{ variant.method_name }}(
            ApiJson.decodeFromJsonElement({{ variant.data_type }}.serializer(), message.data ?: JsonNull),
            message,
        )
{% endfor %}        else -> throw {{ helper.dispatch_exception }}("unknown_type", message.type, message)
    }
{% endfor %}
