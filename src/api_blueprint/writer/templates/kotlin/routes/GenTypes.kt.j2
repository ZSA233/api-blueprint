{{ '\n' if not loop.first }}@Serializable{% if proto.enum_wire_type == 'int' %}(with = {{ proto.name }}Serializer::class){% endif %}
public enum class {{ proto.name }}(public val wireValue: {{ 'Int' if proto.enum_wire_type == 'int' else 'String' }}) {
{%- for key, value in proto.enum_members %}
{%- if proto.enum_wire_type != 'int' %}
