{% autoescape false %}package {{ bp.root_package }}.routes.{{ group.package_suffix }}

import {{ bp.root_package }}.runtime.*
{% if group.binary_schemas() %}
import {{ bp.root_package }}.runtime.binary.ApiBinaryBody
{% endif %}
import kotlinx.serialization.builtins.*

public open class Gen{{ group.class_name }} internal constructor(
    private val transport: ApiTransport,
) {
{%- for route in group.routes %}
{%- if route.is_rpc %}

    public open suspend fun {{ route.method_name }}(
{%- if route.query_type %}
        query: {{ route.query_type }},
{%- endif %}
{%- if route.json_type %}
        json: {{ route.json_type }},
{%- endif %}
{%- if route.form_type %}
        form: {{ route.form_type }},
{%- endif %}
{%- if route.binary_type %}
        binary: {{ route.binary_type }},
{%- endif %}
        headers: Map<String, String> = emptyMap(),
    ): {{ route.response_type.text }} {
{%- if route.unwrap_general_wrapper %}
        val envelope = transport.request(
{%- else %}
        return transport.request(
{%- endif %}
            ApiRequest(
                method = "{{ route.http_method }}",
                path = "{{ route.url }}",
{%- if route.query_type %}
                query = query.toQueryMap(),
{%- endif %}
                headers = headers,
{%- if route.json_type %}
                json = json,
                jsonSerializer = {{ route.json_type }}.serializer(),
{%- endif %}
{%- if route.form_type %}
                form = form,
                formSerializer = {{ route.form_type }}.serializer(),
{%- endif %}
{%- if route.binary_type %}
                binary = {% if route.has_binary_schema %}{{ route.binary_wire_type }}.toBinaryBody(binary){% else %}binary{% endif %},
{%- endif %}
                responseSerializer = {{ route.response_serializer_expr }},
                responseMediaType = "{{ route.response_media_type }}",
            )
        )
{%- if route.unwrap_general_wrapper %}
        if (envelope.code != 0) {
            throw ApiCodeError(envelope.code, envelope.message, envelope.toast)
        }
        return envelope.data ?: throw ApiException(200, "Missing response data for {{ route.url }}")
{%- endif %}
    }
{%- if route.has_binary_schema %}

    public open suspend fun {{ route.method_name }}(
{%- if route.query_type %}
        query: {{ route.query_type }},
{%- endif %}
        binary: ApiBinaryBody,
        headers: Map<String, String> = emptyMap(),
    ): {{ route.response_type.text }} {
{%- if route.unwrap_general_wrapper %}
        val envelope = transport.request(
{%- else %}
        return transport.request(
{%- endif %}
            ApiRequest(
                method = "{{ route.http_method }}",
                path = "{{ route.url }}",
{%- if route.query_type %}
                query = query.toQueryMap(),
{%- endif %}
                headers = headers,
                binary = binary,
                responseSerializer = {{ route.response_serializer_expr }},
                responseMediaType = "{{ route.response_media_type }}",
            )
        )
{%- if route.unwrap_general_wrapper %}
        if (envelope.code != 0) {
            throw ApiCodeError(envelope.code, envelope.message, envelope.toast)
        }
        return envelope.data ?: throw ApiException(200, "Missing response data for {{ route.url }}")
{%- endif %}
    }
{%- endif %}
{%- elif route.supports_ws %}

    @Suppress("UNCHECKED_CAST")
    public open fun {{ route.connect_method_name }}(
{%- if route.query_type %}
        query: {{ route.query_type }},
{%- endif %}
        headers: Map<String, String> = emptyMap(),
        protocols: List<String> = emptyList(),
    ): ApiSocketBridge<{{ route.ws_send_type }}, {{ route.ws_recv_type }}> {
        return transport.connectSocket(
            SocketConnectOptions(
                routeId = "{{ route.protocol.route.route_id }}",
                connectionKind = "legacy_ws",
                path = "{{ route.url }}",
{%- if route.query_type %}
                query = query.toQueryMap(),
{%- endif %}
                headers = headers,
                protocols = protocols,
            )
        ) as ApiSocketBridge<{{ route.ws_send_type }}, {{ route.ws_recv_type }}>
    }
{%- elif route.supports_stream %}

    @Suppress("UNCHECKED_CAST")
    public open fun {{ route.subscribe_method_name }}(
{%- if route.query_type %}
        query: {{ route.query_type }},
{%- endif %}
{%- if route.open_type %}
        open: {{ route.open_type }},
{%- endif %}
        headers: Map<String, String> = emptyMap(),
    ): ApiStreamBridge<{{ route.server_message_type }}, {{ route.close_type }}> {
        return transport.openStream(
            StreamConnectOptions(
                routeId = "{{ route.protocol.route.route_id }}",
                connectionKind = "stream",
                path = "{{ route.url }}",
{%- if route.query_type %}
                query = query.toQueryMap(),
{%- endif %}
{%- if route.open_type %}
                open = open,
{%- endif %}
                headers = headers,
            )
        ) as ApiStreamBridge<{{ route.server_message_type }}, {{ route.close_type }}>
    }
{%- elif route.supports_channel %}

    @Suppress("UNCHECKED_CAST")
    public open fun {{ route.open_channel_method_name }}(
{%- if route.query_type %}
        query: {{ route.query_type }},
{%- endif %}
{%- if route.open_type %}
        open: {{ route.open_type }},
{%- endif %}
        headers: Map<String, String> = emptyMap(),
        protocols: List<String> = emptyList(),
    ): ApiChannelBridge<{{ route.server_message_type }}, {{ route.client_message_type }}, {{ route.close_type }}> {
        return transport.openChannel(
            ChannelConnectOptions(
                routeId = "{{ route.protocol.route.route_id }}",
                connectionKind = "channel",
                path = "{{ route.url }}",
{%- if route.query_type %}
                query = query.toQueryMap(),
{%- endif %}
{%- if route.open_type %}
                open = open,
{%- endif %}
                headers = headers,
                protocols = protocols,
            )
        ) as ApiChannelBridge<{{ route.server_message_type }}, {{ route.client_message_type }}, {{ route.close_type }}>
    }
{%- endif %}
{%- endfor %}
{%- for route in group.routes if route.query_type %}

    private fun {{ route.query_type }}.toQueryMap(): Map<String, String?> = mapOf(
{%- for field in route.query_proto.fields %}
        "{{ field.serial_name }}" to {{ field.type.query_expr(field.name, optional=field.optional) }}{% if not loop.last %},{% endif %}
{%- endfor %}
    )
{%- endfor %}
}
{% endautoescape %}
