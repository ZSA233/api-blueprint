package {{ bp.root_package }}.runtime

typealias ApiErrorCode = Int

data class ApiToastSpec(
    val key: String,
    val level: String,
    val default: String,
)

data class ApiToastPayload(
    val key: String = "",
    val level: String = "",
    val default: String = "",
    val text: String = "",
)

class ApiCodeError(
    val code: ApiErrorCode,
    val apiMessage: String? = null,
    val toastPayload: Any? = null,
    val rawBody: String? = null,
    val entry: ApiErrorCatalogEntry? = null,
) : RuntimeException(apiMessage ?: entry?.message ?: "API error $code") {
    constructor(
        entry: ApiErrorCatalogEntry,
        toast: ApiToastPayload = ApiToastPayload(
            key = entry.toast.key,
            level = entry.toast.level,
            default = entry.toast.default,
        ),
    ) : this(
        code = entry.code,
        apiMessage = entry.message,
        toastPayload = toast,
        entry = entry,
    )
}

data class ApiErrorCatalogEntry(
    val id: String,
    val group: String,
    val key: String,
    val code: ApiErrorCode,
    val message: String,
    val toast: ApiToastSpec,
)

fun resolveApiToast(
    toast: ApiToastPayload?,
    translate: ((String) -> String?)? = null,
    fallbackMessage: String = "",
): String {
    if (toast == null) {
        return fallbackMessage
    }
    if (toast.text.isNotEmpty()) {
        return toast.text
    }
    if (toast.key.isNotEmpty() && translate != null) {
        val translated = translate(toast.key)
        if (!translated.isNullOrEmpty()) {
            return translated
        }
    }
    return toast.default.ifEmpty { fallbackMessage }
}
