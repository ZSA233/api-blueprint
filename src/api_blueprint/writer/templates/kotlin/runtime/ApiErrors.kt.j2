package {{ bp.root_package }}.runtime

typealias ApiErrorCode = Int

data class ApiToastSpec(
    val key: String,
    val level: String,
    val default: String,
)

data class ApiToastPayload(
    val key: String = "",
    val level: String = "",
    val default: String = "",
    val text: String = "",
)

class ApiCodeError(
    val entry: ApiErrorCatalogEntry,
    val toast: ApiToastPayload = ApiToastPayload(
        key = entry.toast.key,
        level = entry.toast.level,
        default = entry.toast.default,
    ),
) : RuntimeException(entry.message) {
    val code: ApiErrorCode = entry.code
}

data class ApiErrorCatalogEntry(
    val id: String,
    val group: String,
    val key: String,
    val code: ApiErrorCode,
    val message: String,
    val toast: ApiToastSpec,
)

fun resolveApiToast(
    toast: ApiToastPayload?,
    translate: ((String) -> String?)? = null,
    fallbackMessage: String = "",
): String {
    if (toast == null) {
        return fallbackMessage
    }
    if (toast.text.isNotEmpty()) {
        return toast.text
    }
    if (toast.key.isNotEmpty() && translate != null) {
        val translated = translate(toast.key)
        if (!translated.isNullOrEmpty()) {
            return translated
        }
    }
    return toast.default.ifEmpty { fallbackMessage }
}
