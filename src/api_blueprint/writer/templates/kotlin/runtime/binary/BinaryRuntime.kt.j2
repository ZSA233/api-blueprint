{% autoescape false %}package {{ bp.root_package }}.runtime.binary

import okio.Buffer
import okio.BufferedSink
import okio.ByteString

public enum class BinaryEndian {
    LITTLE,
    BIG,
}

public class BinaryEncodeException(
    public val fieldPath: String,
    message: String,
) : IllegalArgumentException(if (fieldPath.isEmpty()) message else "$fieldPath: $message")

public data class EncodedBinaryBlock(
    public val field: String,
    public val count: Long,
    public val bytes: ByteString,
) {
    public val byteSize: Long
        get() = bytes.size.toLong()
}

public interface ApiBinaryBody {
    public val contentType: String
        get() = "application/octet-stream"
    public val contentLength: Long?
        get() = null

    public fun writeTo(sink: BufferedSink)
}

public class RawBinaryBody(
    private val bytes: ByteArray,
    override val contentType: String = "application/octet-stream",
) : ApiBinaryBody {
    public override val contentLength: Long = bytes.size.toLong()

    public override fun writeTo(sink: BufferedSink) {
        sink.write(bytes)
    }
}

public class StreamingBinaryBody(
    override val contentType: String = "application/octet-stream",
    override val contentLength: Long? = null,
    private val endian: BinaryEndian = BinaryEndian.LITTLE,
    private val write: (BinaryWriter) -> Unit,
) : ApiBinaryBody {
    public override fun writeTo(sink: BufferedSink) {
        write(BinaryWriter(sink, endian))
    }
}

public fun ApiBinaryBody.toByteArray(): ByteArray {
    val buffer = Buffer()
    writeTo(buffer)
    return buffer.readByteArray()
}

public class BinaryWriter(
    private val sink: BufferedSink,
    private val endian: BinaryEndian = BinaryEndian.LITTLE,
) {
    private val scratch: ByteArray = ByteArray(8)

    public fun writeU8(path: String, value: Int) {
        requireRange(path, value.toLong(), 0L, 0xFFL)
        sink.writeByte(value and 0xFF)
    }

    public fun writeU16(path: String, value: Int) {
        requireRange(path, value.toLong(), 0L, 0xFFFFL)
        if (endian == BinaryEndian.LITTLE) {
            sink.writeByte(value and 0xFF)
            sink.writeByte((value ushr 8) and 0xFF)
        } else {
            sink.writeByte((value ushr 8) and 0xFF)
            sink.writeByte(value and 0xFF)
        }
    }

    public fun writeU24(path: String, value: Int) {
        requireRange(path, value.toLong(), 0L, 0xFF_FFFFL)
        if (endian == BinaryEndian.LITTLE) {
            sink.writeByte(value and 0xFF)
            sink.writeByte((value ushr 8) and 0xFF)
            sink.writeByte((value ushr 16) and 0xFF)
        } else {
            sink.writeByte((value ushr 16) and 0xFF)
            sink.writeByte((value ushr 8) and 0xFF)
            sink.writeByte(value and 0xFF)
        }
    }

    public fun writeU32(path: String, value: Long) {
        requireRange(path, value, 0L, 0xFFFF_FFFFL)
        writeIntBytes(value)
    }

    public fun writeU64(path: String, value: Long) {
        requireNonNegative(path, value)
        writeLongBytes(value)
    }

    public fun writeI8(path: String, value: Int) {
        requireRange(path, value.toLong(), Byte.MIN_VALUE.toLong(), Byte.MAX_VALUE.toLong())
        sink.writeByte(value and 0xFF)
    }

    public fun writeI16(path: String, value: Int) {
        requireRange(path, value.toLong(), Short.MIN_VALUE.toLong(), Short.MAX_VALUE.toLong())
        writeU16(path, value and 0xFFFF)
    }

    public fun writeI24(path: String, value: Int) {
        requireRange(path, value.toLong(), -0x80_0000L, 0x7F_FFFFL)
        writeU24(path, value and 0xFF_FFFF)
    }

    public fun writeI32(path: String, value: Int) {
        writeIntBytes(value.toLong())
    }

    public fun writeI64(path: String, value: Long) {
        writeLongBytes(value)
    }

    public fun writeF32(path: String, value: Float) {
        writeIntBytes(java.lang.Float.floatToIntBits(value).toLong())
    }

    public fun writeF64(path: String, value: Double) {
        writeLongBytes(java.lang.Double.doubleToLongBits(value))
    }

    public fun writeBool(path: String, value: Boolean) {
        sink.writeByte(if (value) 1 else 0)
    }

    public fun writeBytes(path: String, value: ByteArray) {
        sink.write(value)
    }

    public fun writeByteString(path: String, value: ByteString) {
        sink.write(value)
    }

    public fun writeBlock(path: String, block: EncodedBinaryBlock) {
        sink.write(block.bytes)
    }

    public fun writeZeroes(path: String, count: Long) {
        requireNonNegative(path, count)
        var remaining = count
        while (remaining > 0L) {
            val chunk = minOf(remaining, ZERO_CHUNK.size.toLong()).toInt()
            sink.write(ZERO_CHUNK, 0, chunk)
            remaining -= chunk.toLong()
        }
    }

    public fun writeBytesExact(path: String, value: ByteArray, size: Long) {
        requireSize(path, value.size.toLong(), size)
        sink.write(value)
    }

    public fun writeByteStringExact(path: String, value: ByteString, size: Long) {
        requireSize(path, value.size.toLong(), size)
        sink.write(value)
    }

    public fun writeUtf8String(path: String, value: String) {
        sink.write(value.toByteArray(Charsets.UTF_8))
    }

    public fun writeUtf8StringExact(path: String, value: String, size: Long) {
        val bytes = value.toByteArray(Charsets.UTF_8)
        requireSize(path, bytes.size.toLong(), size)
        sink.write(bytes)
    }

    private fun writeIntBytes(value: Long) {
        if (endian == BinaryEndian.LITTLE) {
            scratch[0] = (value and 0xFFL).toByte()
            scratch[1] = ((value ushr 8) and 0xFFL).toByte()
            scratch[2] = ((value ushr 16) and 0xFFL).toByte()
            scratch[3] = ((value ushr 24) and 0xFFL).toByte()
        } else {
            scratch[0] = ((value ushr 24) and 0xFFL).toByte()
            scratch[1] = ((value ushr 16) and 0xFFL).toByte()
            scratch[2] = ((value ushr 8) and 0xFFL).toByte()
            scratch[3] = (value and 0xFFL).toByte()
        }
        sink.write(scratch, 0, 4)
    }

    private fun writeLongBytes(value: Long) {
        if (endian == BinaryEndian.LITTLE) {
            for (index in 0 until 8) {
                scratch[index] = ((value ushr (index * 8)) and 0xFFL).toByte()
            }
        } else {
            for (index in 0 until 8) {
                scratch[index] = ((value ushr ((7 - index) * 8)) and 0xFFL).toByte()
            }
        }
        sink.write(scratch, 0, 8)
    }
}

private val ZERO_CHUNK: ByteArray = ByteArray(8192)

public fun requireBinary(path: String, condition: Boolean, message: String) {
    if (!condition) {
        throw BinaryEncodeException(path, message)
    }
}

public fun requireRange(path: String, value: Long, min: Long, max: Long) {
    if (value < min || value > max) {
        throw BinaryEncodeException(path, "value $value is outside range $min..$max")
    }
}

public fun requireNonNegative(path: String, value: Long) {
    if (value < 0L) {
        throw BinaryEncodeException(path, "value $value cannot be encoded as unsigned")
    }
}

public fun requireSize(path: String, actual: Long, expected: Long) {
    if (actual != expected) {
        throw BinaryEncodeException(path, "size $actual does not match expected $expected")
    }
}

public fun binarySize(value: ByteArray): Long = value.size.toLong()

public fun binarySize(value: ByteString): Long = value.size.toLong()

public fun binarySize(value: String): Long = value.toByteArray(Charsets.UTF_8).size.toLong()

public fun binarySize(value: Collection<*>): Long = value.size.toLong()
