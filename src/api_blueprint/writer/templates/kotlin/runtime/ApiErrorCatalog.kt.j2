package {{ bp.root_package }}.runtime

val ERROR_CATALOG_BY_ID: Map<String, ApiErrorCatalogEntry> = mapOf(
{% for error in writer.error_catalog_for_bp(bp) %}    {{ error.id | code_literal }} to ApiErrorCatalogEntry(
        id = {{ error.id | code_literal }},
        group = {{ error.group | code_literal }},
        key = {{ error.key | code_literal }},
        code = {{ error.code }},
        message = {{ error.message | code_literal }},
        toast = ApiToastSpec(
            key = {{ error.toast.key | code_literal }},
            level = {{ error.toast.level | code_literal }},
            default = {{ error.toast.default | code_literal }},
        ),
    ),
{% endfor %})

val ERROR_CATALOG: Map<String, ApiErrorCatalogEntry> = ERROR_CATALOG_BY_ID

fun lookupApiErrorById(id: String): ApiErrorCatalogEntry? = ERROR_CATALOG_BY_ID[id]

fun lookupApiErrorByCode(code: ApiErrorCode): ApiErrorCatalogEntry? =
    ERROR_CATALOG_BY_ID.values.firstOrNull { it.code == code }

