package {{ bp.root_package }}.runtime

val ApiErrorsByID: Map<String, ApiErrorEntry> = mapOf(
{% for error in writer.api_errors_for_bp(bp) %}    {{ error.id | code_literal }} to ApiErrorEntry(
        id = {{ error.id | code_literal }},
        group = {{ error.group | code_literal }},
        key = {{ error.key | code_literal }},
        code = {{ error.code }},
        message = {{ error.message | code_literal }},
        toast = ApiToastSpec(
            key = {{ error.toast.key | code_literal }},
            level = {{ error.toast.level | code_literal }},
            default = {{ error.toast.default | code_literal }},
        ),
    ),
{% endfor %})

val ApiErrors: Map<String, ApiErrorEntry> = ApiErrorsByID

private val routeApiErrorsByCode: Map<String, Map<ApiErrorCode, ApiErrorEntry>> = mapOf(
{% for route_id, route_entries in writer.route_api_errors_for_bp(bp).items() %}    {{ route_id | code_literal }} to mapOf(
{% for error in route_entries %}        {{ error.code }} to ApiErrorsByID.getValue({{ error.id | code_literal }}),
{% endfor %}    ),
{% endfor %})

fun lookupApiErrorById(id: String): ApiErrorEntry? = ApiErrorsByID[id]

fun lookupApiErrorByCode(code: ApiErrorCode, routeId: String? = null): ApiErrorEntry? {
    if (!routeId.isNullOrEmpty()) {
        routeApiErrorsByCode[routeId]?.get(code)?.let { return it }
    }
    return ApiErrorsByID.values.firstOrNull { it.code == code }
}

fun lookupApiError(payload: ApiErrorPayload?, routeId: String? = null): ApiErrorEntry? {
    if (payload == null) {
        return null
    }
    if (payload.id.isNotEmpty()) {
        lookupApiErrorById(payload.id)?.let { return it }
    }
    return lookupApiErrorByCode(payload.code, routeId)
}

fun apiErrorPayload(
    id: String = "",
    group: String = "",
    key: String = "",
    code: ApiErrorCode = 0,
    message: String = "",
    toast: ApiToastPayload = ApiToastPayload(),
    routeId: String? = null,
): ApiErrorPayload {
    val seed = ApiErrorPayload(id = id, group = group, key = key, code = code, message = message, toast = toast)
    val entry = lookupApiError(seed, routeId)
    return ApiErrorPayload(
        id = id.ifEmpty { entry?.id.orEmpty() },
        group = group.ifEmpty { entry?.group.orEmpty() },
        key = key.ifEmpty { entry?.key.orEmpty() },
        code = if (code != 0) code else entry?.code ?: 0,
        message = message.ifEmpty { entry?.message ?: "API error ${if (code != 0) code else entry?.code ?: 0}" },
        toast = ApiToastPayload(
            key = toast.key.ifEmpty { entry?.toast?.key.orEmpty() },
            level = toast.level.ifEmpty { entry?.toast?.level ?: "error" },
            default = toast.default.ifEmpty { entry?.toast?.default.orEmpty() },
            text = toast.text,
        ),
    )
}

