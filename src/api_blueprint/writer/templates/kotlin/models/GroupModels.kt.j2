{% autoescape false %}package {{ writer.package }}.models

import kotlinx.serialization.SerialName
import kotlinx.serialization.Serializable
{% for proto in protos %}
{%- if proto.kind == 'data' %}
{{ '\n' if not loop.first }}@Serializable
public data class {{ proto.name }}(
{%- for field in proto.fields %}
{%- if field.serial_name != field.name %}
    @SerialName("{{ field.serial_name }}")
{%- endif %}
    public val {{ field.name }}: {{ field.type.text }}{% if field.optional %} = null{% endif %}{% if not loop.last %},{% endif %}
{%- endfor %}
)
{%- elif proto.kind == 'alias' %}
{{ '\n' if not loop.first }}public typealias {{ proto.name }} = {{ proto.alias_type.text if proto.alias_type else 'kotlinx.serialization.json.JsonElement' }}
{%- endif %}
{%- endfor %}
{% endautoescape %}
