package {{ bp.root_package }}.runtime;

import java.util.Map;

public record ApiResponse(
    int statusCode,
    byte[] body,
    Map<String, String> headers
) {
    public ApiResponse {
        body = body == null ? new byte[0] : body.clone();
        headers = headers == null ? Map.of() : Map.copyOf(headers);
    }

    @Override
    public byte[] body() {
        return body.clone();
    }
}
