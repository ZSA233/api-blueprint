import {{ bp.root_package }}.runtime.binary.GenApiBinaryBody;

public class {{ group.generated_client_class }} {
    protected final GenApiTransport transport;

    public {{ group.generated_client_class }}(GenApiTransport transport) {
        this.transport = transport;
    }
{% for route in group.routes %}
{% if route.is_rpc %}
{% if route.binary_schema %}

    public {{ writer.response_type(route, group) }} {{ route.method_name }}(
{%- for type_name, name in writer.route_params(route, group) if name != "binaryBody" %}
        {{ type_name }} {{ name }},
{%- endfor %}
        {{ group.types_class }}.{{ route.binary_schema_type }} binary
    ) throws Exception {
        return {{ route.method_name }}(
{%- for type_name, name in writer.route_params(route, group) if name != "binaryBody" %}
            {{ name }},
{%- endfor %}
            binary,
            GenApiRequestOptions.none()
        );
    }

    public {{ writer.response_type(route, group) }} {{ route.method_name }}(
{%- for type_name, name in writer.route_params(route, group) if name != "binaryBody" %}
        {{ type_name }} {{ name }},
{%- endfor %}
        {{ group.types_class }}.{{ route.binary_schema_type }} binary,
        GenApiRequestOptions options
    ) throws Exception {
        return {{ route.method_name }}(
{%- for type_name, name in writer.route_params(route, group) if name != "binaryBody" %}
            {{ name }},
{%- endfor %}
            {{ group.types_class }}.{{ route.binary_schema_type }}Wire.toBinaryBody(binary),
            options
        );
    }
{% endif %}

    public {{ writer.response_type(route, group) }} {{ route.method_name }}(
{%- for type_name, name in writer.route_params(route, group) %}
        {{ type_name }} {{ name }}{% if not loop.last %},{% endif %}
{%- endfor %}
    ) throws Exception {
        return {{ route.method_name }}(
{%- for type_name, name in writer.route_params(route, group) %}
            {{ name }},
{%- endfor %}
            GenApiRequestOptions.none()
        );
    }

    public {{ writer.response_type(route, group) }} {{ route.method_name }}(
{%- for type_name, name in writer.route_params(route, group) %}
        {{ type_name }} {{ name }},
{%- endfor %}
        GenApiRequestOptions options
    ) throws Exception {
        GenApiRequestOptions effectiveOptions = options == null ? GenApiRequestOptions.none() : options;
        GenApiRequest<{{ writer.response_type(route, group) }}> request = new GenApiRequest<>(
            {{ route.route_id | code_literal }},
            {{ route.http_method | code_literal }},
            {{ route.url | code_literal }},
            {% if route.path_model %}path{% else %}null{% endif %},
            {% if route.query_model %}query{% else %}null{% endif %},
            new GenApiRequestBodySpec(
                {% if route.json_model %}json{% else %}null{% endif %},
                {% if route.form_model %}form{% else %}null{% endif %},
                {% if route.multipart_model %}multipart{% else %}null{% endif %},
                {% if route.binary_schema or route.binary_model %}binaryBody{% else %}null{% endif %},
                {{ route.request_body_kind | code_literal }}
            ),
            new GenApiResponseSpec<>(
                {{ route.response_envelope_literal | safe }},
                {{ writer.response_class_literal(route, group) }},
                {{ route.response_media_type | code_literal }},
                {{ route.response_kind | code_literal }},
                {% if route.is_binary_schema_response %}{{ group.types_class }}.{{ route.response_binary_schema_type }}Wire::parse{% else %}null{% endif %}
            ),
            effectiveOptions.headers(),
            effectiveOptions.timeout()
        );
        return transport.execute(request);
    }
{% elif route.kind == "stream" %}

    public GenApiStreamBridge<{{ writer.server_message_type(route, group) }}, Object> {{ route.connection_method_name }}(
{%- for type_name, name in writer.route_params(route, group) %}
        {{ type_name }} {{ name }}{% if not loop.last %},{% endif %}
{%- endfor %}
    ) {
        return {{ route.connection_method_name }}(
{%- for type_name, name in writer.route_params(route, group) %}
            {{ name }},
{%- endfor %}
            GenApiRequestOptions.none()
        );
    }

    public GenApiStreamBridge<{{ writer.server_message_type(route, group) }}, Object> {{ route.connection_method_name }}(
{%- for type_name, name in writer.route_params(route, group) %}
        {{ type_name }} {{ name }},
{%- endfor %}
        GenApiRequestOptions options
    ) {
        GenApiRequestOptions effectiveOptions = options == null ? GenApiRequestOptions.none() : options;
        GenApiRequest<Object> request = new GenApiRequest<>(
            {{ route.route_id | code_literal }},
            "STREAM",
            {{ route.url | code_literal }},
            null,
            {% if route.query_model %}query{% else %}null{% endif %},
            new GenApiRequestBodySpec(
                {% if route.open_model %}openData{% else %}null{% endif %},
                null,
                null,
                null,
                "none"
            ),
            new GenApiResponseSpec<>(
                GenApiResponseEnvelope.none(),
                Object.class,
                "application/json",
                "json",
                null
            ),
            effectiveOptions.headers(),
            effectiveOptions.timeout()
        );
        return transport.openStream(request);
    }
{% elif route.kind == "channel" %}

    public GenApiChannelBridge<{{ writer.server_message_type(route, group) }}, {{ writer.client_message_type(route, group) }}, Object> {{ route.connection_method_name }}(
{%- for type_name, name in writer.route_params(route, group) %}
        {{ type_name }} {{ name }}{% if not loop.last %},{% endif %}
{%- endfor %}
    ) {
        return {{ route.connection_method_name }}(
{%- for type_name, name in writer.route_params(route, group) %}
            {{ name }},
{%- endfor %}
            GenApiRequestOptions.none()
        );
    }

    public GenApiChannelBridge<{{ writer.server_message_type(route, group) }}, {{ writer.client_message_type(route, group) }}, Object> {{ route.connection_method_name }}(
{%- for type_name, name in writer.route_params(route, group) %}
        {{ type_name }} {{ name }},
{%- endfor %}
        GenApiRequestOptions options
    ) {
        GenApiRequestOptions effectiveOptions = options == null ? GenApiRequestOptions.none() : options;
        GenApiRequest<Object> request = new GenApiRequest<>(
            {{ route.route_id | code_literal }},
            "CHANNEL",
            {{ route.url | code_literal }},
            null,
            {% if route.query_model %}query{% else %}null{% endif %},
            new GenApiRequestBodySpec(
                {% if route.open_model %}openData{% else %}null{% endif %},
                null,
                null,
                null,
                "none"
            ),
            new GenApiResponseSpec<>(
                GenApiResponseEnvelope.none(),
                Object.class,
                "application/json",
                "json",
                null
            ),
            effectiveOptions.headers(),
            effectiveOptions.timeout()
        );
        return transport.openChannel(request);
    }
{% endif %}
{% endfor %}
}
{% endautoescape %}
