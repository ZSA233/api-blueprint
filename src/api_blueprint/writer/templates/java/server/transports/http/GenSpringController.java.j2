        @RequestParam Map<String, String> queryParams{% if route.json_model %},
        @RequestBody(required = false) {{ writer.schema_type(route.json_model, group) }} json{% elif route.binary_schema or route.binary_model %},
        @RequestBody(required = false) byte[] binaryBody{% endif %}
    ) throws Exception {
{%- if route.query_model %}
        {{ writer.schema_type(route.query_model, group) }} query = objectMapper.convertValue(queryParams, {{ writer.schema_class_literal(route.query_model, group) }});
{%- endif %}
{%- if route.form_model %}
        {{ writer.schema_type(route.form_model, group) }} form = objectMapper.convertValue(queryParams, {{ writer.schema_class_literal(route.form_model, group) }});
{%- endif %}
{%- if route.binary_schema %}
        {{ group.types_class }}.{{ route.binary_schema_type }} binary = {{ group.types_class }}.{{ route.binary_schema_type }}Wire.parse(binaryBody == null ? new byte[0] : binaryBody);
{%- endif %}
        try {
            Object result = service.{{ route.method_name }}(
{%- for type_name, name in writer.route_params(route, group) %}
                {{ name }}{% if not loop.last %},{% endif %}
{%- endfor %}
            );
            return wrapResponse({{ route.response_envelope_literal | safe }}, result);
        } catch (ApiError error) {
            return wrapApiErrorResponse({{ route.response_envelope_literal | safe }}, error, {{ route.route_id | code_literal }});
        }
    }
{% else %}

    @RequestMapping(path = {{ route.url | code_literal }}, method = RequestMethod.GET)
    public ResponseEntity<String> {{ route.method_name }}Unsupported() {
        return ResponseEntity.status(HttpStatus.NOT_IMPLEMENTED).body("{{ route.kind }} route is not implemented by the generated Spring MVC adapter");
    }
{% endif %}
