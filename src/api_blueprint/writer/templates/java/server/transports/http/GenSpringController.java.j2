    private static Map<String, String> parseQuery(URI uri) {
        if (uri == null || uri.getRawQuery() == null || uri.getRawQuery().isBlank()) {
            return Map.of();
        }
        Map<String, String> result = new LinkedHashMap<>();
        for (String part : uri.getRawQuery().split("&")) {
            if (part.isBlank()) {
                continue;
            }
            int separator = part.indexOf('=');
            String key = separator >= 0 ? part.substring(0, separator) : part;
            String value = separator >= 0 ? part.substring(separator + 1) : "";
            result.put(
                URLDecoder.decode(key, StandardCharsets.UTF_8),
                URLDecoder.decode(value, StandardCharsets.UTF_8)
            );
        }
        return result;
    }

    private Object wrapResponse(GenApiResponseEnvelope envelopeSpec, Object data) {
        if ("none".equals(envelopeSpec.kind())) {
            return data;
        }
        Map<String, Object> envelope = new LinkedHashMap<>();
        if ("code_message_data".equals(envelopeSpec.kind())) {
            envelope.put(envelopeSpec.fields().code(), envelopeSpec.successCode());
            envelope.put(envelopeSpec.fields().message(), envelopeSpec.successMessage());
            envelope.put(envelopeSpec.fields().data(), data);
            return envelope;
        }
        if ("ok_data_error".equals(envelopeSpec.kind())) {
            envelope.put(envelopeSpec.fields().ok(), true);
            envelope.put(envelopeSpec.fields().data(), data);
            return envelope;
        }
        return envelope;
    }

    private <T> T multipartBody(MultipartHttpServletRequest request, Class<T> targetClass) throws IOException {
        Map<String, Object> values = multipartValues(request);
        if (!targetClass.isRecord()) {
            return objectMapper.convertValue(values, targetClass);
        }
        RecordComponent[] components = targetClass.getRecordComponents();
        Class<?>[] parameterTypes = new Class<?>[components.length];
        Object[] args = new Object[components.length];
        for (int index = 0; index < components.length; index++) {
            RecordComponent component = components[index];
            parameterTypes[index] = component.getType();
            String key = recordComponentWireName(component);
            Object raw = values.containsKey(key) ? values.get(key) : values.get(component.getName());
            if (raw instanceof GenApiFilePart && component.getType().equals(GenApiFilePart.class)) {
                args[index] = raw;
            } else {
                args[index] = objectMapper.convertValue(raw, component.getType());
            }
        }
        try {
            Constructor<T> constructor = targetClass.getDeclaredConstructor(parameterTypes);
            constructor.setAccessible(true);
            return constructor.newInstance(args);
        } catch (ReflectiveOperationException error) {
            throw new IllegalArgumentException("invalid multipart request", error);
        }
    }

    private Map<String, Object> multipartValues(MultipartHttpServletRequest request) throws IOException {
        Map<String, Object> result = new LinkedHashMap<>();
        if (request == null) {
            return result;
        }
        request.getParameterMap().forEach((key, values) -> {
            if (values != null && values.length > 0) {
                result.put(key, values[0]);
            }
        });
        for (Map.Entry<String, MultipartFile> entry : request.getFileMap().entrySet()) {
            MultipartFile file = entry.getValue();
            if (file.getSize() > serverConfig.multipartSingleFileBytes()) {
                throw new PayloadTooLargeException("multipart file " + entry.getKey() + " exceeds configured limit");
            }
            result.put(entry.getKey(), GenApiFilePart.ofStream(file.getOriginalFilename(), file.getContentType(), file.getSize(), file.getInputStream()));
        }
        return result;
    }

    private String recordComponentWireName(RecordComponent component) {
        JsonProperty property = component.getAnnotation(JsonProperty.class);
        return property == null || property.value().isBlank() ? component.getName() : property.value();
    }

