    private final ObjectMapper objectMapper;

    public {{ group.controller_class }}(
        @Autowired(required = false) {{ group.service_class }} service,
        ObjectMapper objectMapper
    ) {
        this.service = service == null ? new {{ group.stub_class }}() : service;
        this.objectMapper = objectMapper;
    }
{% for route in group.routes %}
{% if route.is_rpc %}

    @RequestMapping(path = {{ route.url | code_literal }}, method = RequestMethod.{{ route.http_method }})
