package {{ bp.root_package }}.runtime;

import java.util.Map;

public record ApiStreamResponse(
    byte[] body,
    String contentType,
    Map<String, String> headers
) {
    public ApiStreamResponse {
        body = body == null ? new byte[0] : body.clone();
        contentType = contentType == null || contentType.isBlank() ? "application/octet-stream" : contentType;
        headers = headers == null ? Map.of() : Map.copyOf(headers);
    }

    @Override
    public byte[] body() {
        return body.clone();
    }

    public static ApiStreamResponse of(byte[] body, String contentType) {
        return new ApiStreamResponse(body, contentType, Map.of());
    }
}
