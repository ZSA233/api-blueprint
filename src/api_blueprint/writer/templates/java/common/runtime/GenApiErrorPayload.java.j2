package {{ bp.root_package }}.runtime;

public record GenApiErrorPayload(
    String id,
    String group,
    String key,
    int code,
    String message,
    GenApiToastPayload toast
) {
    public GenApiErrorPayload {
        id = id == null ? "" : id;
        group = group == null ? "" : group;
        key = key == null ? "" : key;
        message = message == null ? "" : message;
        toast = toast == null ? new GenApiToastPayload("", "error", "", "") : toast;
    }
}
