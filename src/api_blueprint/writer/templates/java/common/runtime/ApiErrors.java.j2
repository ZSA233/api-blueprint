package {{ bp.root_package }}.runtime;

import java.util.Map;
import java.util.Optional;

public final class ApiErrors {
    private ApiErrors() {
    }
{% for entry in errors %}

    public static final int {{ writer.constant_name(entry.group ~ "_" ~ entry.key) }} = {{ entry.code }};
{% endfor %}

    public static final Map<String, ApiErrorEntry> API_ERRORS_BY_ID = Map.ofEntries(
{%- for entry in errors %}
        Map.entry(
            {{ entry.id | code_literal }},
            new ApiErrorEntry(
                {{ entry.id | code_literal }},
                {{ entry.group | code_literal }},
                {{ entry.key | code_literal }},
                {{ entry.code }},
                {{ entry.message | code_literal }},
                new ApiToastSpec(
                    {{ entry.toast.key | code_literal }},
                    {{ entry.toast.level | code_literal }},
                    {{ entry.toast.default | code_literal }}
                )
            )
        ){% if not loop.last %},{% endif %}
{%- endfor %}
    );

    public static final Map<String, ApiErrorEntry> ApiErrorsByID = API_ERRORS_BY_ID;

{% for group in errors | groupby("group") %}    public static final class {{ group.list[0].group_symbol }} {
        private {{ group.list[0].group_symbol }}() {
        }
{% for entry in group.list %}
        public static final ApiErrorEntry {{ entry.key_symbol }} = API_ERRORS_BY_ID.get({{ entry.id | code_literal }});
{% endfor %}
    }

{% endfor %}

    private static final Map<String, Map<Integer, ApiErrorEntry>> ROUTE_API_ERRORS_BY_CODE = Map.ofEntries(
{%- for route_id, route_entries in route_errors.items() %}
        Map.entry(
            {{ route_id | code_literal }},
            Map.ofEntries(
{%- for entry in route_entries %}
                Map.entry({{ entry.code }}, API_ERRORS_BY_ID.get({{ entry.id | code_literal }})){% if not loop.last %},{% endif %}
{%- endfor %}
            )
        ){% if not loop.last %},{% endif %}
{%- endfor %}
    );

    public static Optional<ApiErrorEntry> findById(String id) {
        return Optional.ofNullable(API_ERRORS_BY_ID.get(id));
    }

    public static Optional<ApiErrorEntry> findByCode(int code, String routeId) {
        if (routeId != null && !routeId.isBlank()) {
            ApiErrorEntry routeEntry = ROUTE_API_ERRORS_BY_CODE.getOrDefault(routeId, Map.of()).get(code);
            if (routeEntry != null) {
                return Optional.of(routeEntry);
            }
        }
        return API_ERRORS_BY_ID.values().stream().filter(item -> item.code() == code).findFirst();
    }

    public static Optional<ApiErrorEntry> lookup(ApiErrorPayload payload, String routeId) {
        if (payload == null) {
            return Optional.empty();
        }
        if (payload.id() != null && !payload.id().isBlank()) {
            Optional<ApiErrorEntry> byId = findById(payload.id());
            if (byId.isPresent()) {
                return byId;
            }
        }
        return findByCode(payload.code(), routeId);
    }
}
