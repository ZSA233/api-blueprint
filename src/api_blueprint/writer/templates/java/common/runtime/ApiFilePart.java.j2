package {{ bp.root_package }}.runtime;

public record ApiFilePart(
    String filename,
    String contentType,
    byte[] bytes
) {
    public ApiFilePart {
        filename = filename == null ? "" : filename;
        contentType = contentType == null || contentType.isBlank() ? "application/octet-stream" : contentType;
        bytes = bytes == null ? new byte[0] : bytes.clone();
    }

    @Override
    public byte[] bytes() {
        return bytes.clone();
    }

    public static ApiFilePart of(String filename, String contentType, byte[] bytes) {
        return new ApiFilePart(filename, contentType, bytes);
    }
}
