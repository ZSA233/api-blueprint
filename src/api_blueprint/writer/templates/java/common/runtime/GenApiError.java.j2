package {{ bp.root_package }}.runtime;

public class GenApiError extends RuntimeException {
    private final GenApiErrorPayload payload;
    private final String routeId;
    private final String rawBody;
    private final GenApiErrorEntry entry;

    public GenApiError(GenApiErrorPayload payload, String routeId, String rawBody, GenApiErrorEntry entry) {
        super(payload.message() == null || payload.message().isBlank() ? "API error " + payload.code() : payload.message());
        this.payload = payload;
        this.routeId = routeId;
        this.rawBody = rawBody;
        this.entry = entry;
    }

    public GenApiErrorPayload payload() {
        return payload;
    }

    public int code() {
        return payload.code();
    }

    public String id() {
        return payload.id();
    }

    public String group() {
        return payload.group();
    }

    public String key() {
        return payload.key();
    }

    public String apiMessage() {
        return payload.message();
    }

    public GenApiToastPayload toast() {
        return payload.toast();
    }

    public String routeId() {
        return routeId;
    }

    public String rawBody() {
        return rawBody;
    }

    public GenApiErrorEntry entry() {
        return entry;
    }

    public boolean is(GenApiErrorEntry expected) {
        if (expected == null) {
            return false;
        }
        if (expected.id() != null && !expected.id().isBlank() && expected.id().equals(id())) {
            return true;
        }
        return expected.code() != 0 && expected.code() == code();
    }

    public static String resolveApiToast(GenApiToastPayload toast, java.util.function.Function<String, String> translate, String fallbackMessage) {
        if (toast == null) {
            return fallbackMessage;
        }
        if (!toast.text().isEmpty()) {
            return toast.text();
        }
        if (!toast.key().isEmpty() && translate != null) {
            String translated = translate.apply(toast.key());
            if (translated != null && !translated.isEmpty()) {
                return translated;
            }
        }
        return toast.defaultMessage().isEmpty() ? fallbackMessage : toast.defaultMessage();
    }
}
