{% autoescape false %}from __future__ import annotations

from dataclasses import dataclass

from {{ runtime_import_prefix }}runtime.binary import (
    ApiBinaryBody,
    BinaryEncodeError,
    BinaryWriter,
    EncodedBinaryBlock,
    StreamingBinaryBody,
    is_api_binary_body,
    require_binary,
    require_range,
    require_size,
    wrap_binary_field,
    wrap_binary_index,
)


{% macro check_field(field, receiver, number_expr, path) -%}
{% if field.rule.get("const") %}
{% if field.is_bytes or field.is_string or field.wire_type == "bool" %}
    require_binary({{ path | code_literal }}, {{ receiver }} == {{ field.const_expr }}, "const mismatch")
{% else %}
    require_binary({{ path | code_literal }}, int({{ receiver }}) == int({{ field.const_expr }}), "const mismatch")
{% endif %}
{% endif %}
{% if field.rule.get("min") and field.is_integer_scalar %}
    require_range({{ path | code_literal }}, int({{ receiver }}), {{ field.min_expr }}, 2**63 - 1)
{% endif %}
{% if field.rule.get("max") and field.is_integer_scalar %}
    require_range({{ path | code_literal }}, int({{ receiver }}), -(2**63), {{ field.max_expr }})
{% endif %}
{% if field.rule.get("assert") and field.is_integer_scalar %}
    require_binary({{ path | code_literal }}, int({{ receiver }}) == {{ field.assert_expr }}, "assert mismatch")
{% endif %}
{% if field.bitflags_zero_mask %}
    require_binary({{ path | code_literal }}, (int({{ receiver }}) & {{ field.bitflags_zero_mask }}) == 0, "reserved bits must be zero")
{% endif %}
{%- endmacro %}

{% macro write_field(field, object) -%}
{% set path = field.name %}
{% if field.is_hidden %}
    writer.write_zeroes({{ path | code_literal }}, {{ field.count_expr }})
{% elif field.is_bytes %}
{% if field.rule.get("const") %}
{{ check_field(field, field.value_expr, field.value_expr, path) }}
    require_size({{ path | code_literal }}, len({{ field.value_expr }}), {{ field.count_expr }})
    writer.write_bytes({{ path | code_literal }}, {{ field.value_expr }})
{% else %}
    {{ field.py_name }}_count = {{ field.count_expr }}
{% if field.rule.get("max") %}
    require_range({{ path | code_literal }}, {{ field.py_name }}_count, 0, {{ field.max_expr }})
{% endif %}
    require_size({{ path | code_literal }}, len({{ field.value_expr }}), {{ field.py_name }}_count)
    writer.write_bytes({{ path | code_literal }}, {{ field.value_expr }})
{% endif %}
{% elif field.is_string %}
    {{ field.py_name }}_count = {{ field.count_expr }}
{% if field.rule.get("max") %}
    require_range({{ path | code_literal }}, {{ field.py_name }}_count, 0, {{ field.max_expr }})
{% endif %}
    require_size({{ path | code_literal }}, len({{ field.value_expr }}.encode("utf-8")), {{ field.py_name }}_count)
    writer.write_string({{ path | code_literal }}, {{ field.value_expr }})
{% elif field.is_array %}
    {{ field.py_name }}_count = {{ field.count_expr }}
{% if field.rule.get("max") %}
    require_range({{ path | code_literal }}, {{ field.py_name }}_count, 0, {{ field.max_expr }})
{% endif %}
    require_size({{ path | code_literal }}, len({{ field.value_expr }}), {{ field.py_name }}_count)
    for index, item in enumerate({{ field.value_expr }}):
{% if field.is_scalar %}
        try:
            writer.{{ field.write_method }}("", item)
        except BinaryEncodeError as err:
            raise wrap_binary_index({{ path | code_literal }}, index, err) from err
{% else %}
        try:
            {{ field.schema.object_writer_name(field.typ) }}(item, writer, state, path="")
        except BinaryEncodeError as err:
            raise wrap_binary_index({{ path | code_literal }}, index, err) from err
{% endif %}
{% elif field.is_scalar %}
{{ check_field(field, field.value_expr, field.value_expr, path) }}
{% if field.sizeof_name and object.has_public_field(field.sizeof_name) %}
    require_size({{ (path ~ "." ~ field.sizeof_name) | code_literal }}, len(value.{{ field.sizeof_py_name }}), int({{ field.value_expr }}))
{% endif %}
    writer.{{ field.write_method }}({{ path | code_literal }}, {{ field.value_expr }})
{% if field.is_integer_scalar %}
    state[{{ field.py_name | code_literal }}] = int({{ field.value_expr }})
{% endif %}
{% else %}
    try:
        {{ field.schema.object_writer_name(field.typ) }}({{ field.value_expr }}, writer, state, path="")
    except BinaryEncodeError as err:
        raise wrap_binary_field({{ path | code_literal }}, err) from err
{% endif %}
{%- endmacro %}

{% for schema in binary_schemas %}
{% for value_set in schema.value_sets %}
class {{ value_set.py_type }}:
{% for value in value_set.values %}    {{ value_set.value_name(value.name) }} = {{ value.value }}
{% endfor %}

{% endfor %}
@dataclass
class {{ schema.py_type }}:
{% for section in schema.sections %}    {{ schema.packet_field_name(section.name) }}: {{ section.py_type }}
{% endfor %}


class {{ schema.py_type }}Wire:
    CONTENT_TYPE = {{ schema.content_type | code_literal }}

    @staticmethod
    def body(write, content_length: int | None = None) -> ApiBinaryBody:
        return StreamingBinaryBody(
            write=write,
            content_length=content_length,
            content_type={{ schema.content_type | code_literal }},
            endian={{ schema.endian }},
        )

    @staticmethod
    def to_binary_body(value: {{ schema.py_type }} | ApiBinaryBody) -> ApiBinaryBody:
        if is_api_binary_body(value):
            return value
        return {{ schema.py_type }}Wire.body(lambda writer: {{ schema.writer_name }}(value, writer))


def {{ schema.writer_name }}(value: {{ schema.py_type }}, writer: BinaryWriter) -> None:
    state = {
{% for field_name in schema.state_fields %}        {{ field_name | code_literal }}: 0,
{% endfor %}    }
{% for section in schema.sections %}    try:
        {{ section.writer_name }}(value.{{ schema.packet_field_name(section.name) }}, writer, state, path="")
    except BinaryEncodeError as err:
        raise wrap_binary_field({{ (schema.name ~ "." ~ schema.packet_field_name(section.name)) | code_literal }}, err) from err
{% endfor %}


{% for object in schema.objects %}
@dataclass
class {{ object.py_type }}:
{% if object.data_fields %}
{% for field in object.data_fields %}    {{ field.py_name }}: {{ field.py_type }}
{% endfor %}
{% else %}    pass
{% endif %}


def {{ object.writer_name }}(
    value: {{ object.py_type }},
    writer: BinaryWriter,
    state: dict[str, int],
    path: str = {{ object.path_name | code_literal }},
) -> None:
    try:
{% for field in object.fields %}{{ write_field(field, object) | indent(4, true) }}
{% endfor %}    except BinaryEncodeError as err:
        if not path:
            raise
        raise wrap_binary_field(path, err) from err

{% endfor %}
{% endfor %}
{% endautoescape %}
