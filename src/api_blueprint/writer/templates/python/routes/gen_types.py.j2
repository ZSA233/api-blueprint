{% for variant in helper.variants %}    {{ variant.method_name }}: Callable[[{{ variant.data_type }}, {{ helper.name }}], R]
{% endfor %}


class {{ helper.error_class }}(Exception):
    def __init__(self, kind: str = "unknown_type", raw_message: {{ helper.name }} | None = None):
        message_type = "" if raw_message is None else raw_message.type
        super().__init__(f"unsupported {{ helper.name }} type {message_type}")
        self.kind = kind
        self.type = message_type
        self.raw_message = raw_message


def {{ helper.is_error_func }}(error: BaseException) -> bool:
    return isinstance(error, {{ helper.error_class }})


def {{ helper.dispatch_func }}(
    message: {{ helper.name }} | Mapping[str, Any],
    handlers: {{ helper.handlers_class }}[R],
) -> R:
    typed_message = _coerce_message({{ helper.name }}, message)
    match typed_message.type:
{% for variant in helper.variants %}        case {{ variant.key | tojson }}:
            return handlers.{{ variant.method_name }}(
                _from_mapping({{ variant.data_type }}, typed_message.data),
                typed_message,
            )
{% endfor %}        case _:
            raise {{ helper.error_class }}("unknown_type", typed_message)


{% endfor %}
