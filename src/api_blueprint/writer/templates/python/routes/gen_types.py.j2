{% if group.message_helpers() %}
R = TypeVar("R")


def _to_mapping(value: object) -> Mapping[str, Any] | None:
    if value is None:
        return None
    if isinstance(value, Mapping):
        return value
    if is_dataclass(value):
        return {key: item for key, item in asdict(value).items() if item is not None}
    raise TypeError(f"expected mapping or dataclass message data, got {type(value).__name__}")


def _from_mapping(model_type, value):
    if value is None or isinstance(value, model_type):
        return value
    if isinstance(value, Mapping):
        return model_type(**{key: value.get(key) for key in model_type.__dataclass_fields__})
    return value


def _coerce_message(model_type, value):
    if isinstance(value, model_type):
        return value
    if isinstance(value, Mapping):
        return model_type(type=str(value.get("type", "")), data=value.get("data"))
    raise TypeError(f"expected mapping or {model_type.__name__}, got {type(value).__name__}")


