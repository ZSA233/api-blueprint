from .gen_client import *
from .gen_types import *
{% if channel_scaffolds %}

# Preserved channel processor scaffolds. Customize these classes to plug a
# project-owned channel bridge into the generated typed message visitors.

{% for scaffold in channel_scaffolds %}
class {{ scaffold.session_class }}:
    def __init__(
        self,
        bridge: ApiChannelBridge[{{ scaffold.message_type }}, {{ scaffold.send_type }}, {{ scaffold.close_type }}],
        processor: {{ scaffold.processor_type }}[object],
        context: object | None = None,
    ):
        self.bridge = bridge
        self.processor = processor
        self.context = context

    async def serve(self) -> None:
        async for message in self.bridge:
            {{ scaffold.visit_func }}(self.context, message, self.processor)
{% endfor %}
{% endif %}
