from __future__ import annotations

from dataclasses import dataclass, field
from typing import Any, AsyncIterable, BinaryIO, Generic, Iterable, Mapping, Protocol, TypeVar


RecvT = TypeVar("RecvT")
SendT = TypeVar("SendT")
CloseT = TypeVar("CloseT")
RawT = TypeVar("RawT")


ApiUploadFile = bytes | bytearray | memoryview | BinaryIO | tuple[str, bytes] | tuple[str, bytes, str] | Any


@dataclass
class ApiServerContext:
    state: dict[str, Any] = field(default_factory=dict)


@dataclass(frozen=True)
class ApiRawResponse(Generic[RawT]):
    body: RawT
    headers: Mapping[str, str] | None = None
    status: int = 200
    content_type: str | None = None
    filename: str | None = None


ApiByteStream = AsyncIterable[bytes] | Iterable[bytes]


class ApiServerStream(Protocol, Generic[SendT, CloseT]):
    async def send(self, message: SendT) -> None:
        ...

    async def close(self, close: CloseT) -> None:
        ...

    async def abort(self, code: int = 1011, reason: str | None = None) -> None:
        ...


class ApiServerChannel(ApiServerStream[SendT, CloseT], Protocol, Generic[RecvT, SendT, CloseT]):
    async def receive(self) -> RecvT:
        ...
